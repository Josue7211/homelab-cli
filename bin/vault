#!/usr/bin/env bash
# vault - Convenience wrapper around bw (Bitwarden/Vaultwarden CLI)
# Auto-checks unlock status, quick get/search operations.

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
source "$SCRIPT_DIR/../lib/common.sh"

# ── Helpers ──────────────────────────────────────────────────

check_unlocked() {
    require_cmd bw
    local status
    status=$(bw status 2>/dev/null | python3 -c "import sys,json; print(json.load(sys.stdin).get('status','unknown'))" 2>/dev/null || echo "error")
    if [[ "$status" == "locked" ]]; then
        die "Vault is locked. Run: bw unlock"
    elif [[ "$status" == "unauthenticated" ]]; then
        die "Not logged in. Run: bw login"
    elif [[ "$status" != "unlocked" ]]; then
        die "Vault status: $status"
    fi
}

# ── Commands ─────────────────────────────────────────────────

cmd_status() {
    require_cmd bw
    local info
    info=$(bw status 2>/dev/null)
    local status server email
    status=$(echo "$info" | python3 -c "import sys,json; print(json.load(sys.stdin).get('status','?'))" 2>/dev/null)
    server=$(echo "$info" | python3 -c "import sys,json; print(json.load(sys.stdin).get('serverUrl','?'))" 2>/dev/null)
    email=$(echo "$info" | python3 -c "import sys,json; print(json.load(sys.stdin).get('userEmail','?'))" 2>/dev/null)

    local label
    case "$status" in
        unlocked)       label="${GREEN}unlocked${RESET}" ;;
        locked)         label="${YELLOW}locked${RESET}" ;;
        unauthenticated) label="${RED}not logged in${RESET}" ;;
        *)              label="$status" ;;
    esac

    echo -e "  Vault:   $label"
    echo "  Server:  $server"
    echo "  Email:   $email"
}

cmd_get() {
    local name="$1"
    check_unlocked
    bw get password "$name" 2>/dev/null || die "Entry '$name' not found"
}

cmd_user() {
    local name="$1"
    check_unlocked
    bw get username "$name" 2>/dev/null || die "Entry '$name' not found"
}

cmd_item() {
    local name="$1"
    check_unlocked
    bw get item "$name" 2>/dev/null | python3 -c "
import sys, json
item = json.load(sys.stdin)
print(f'  Name:     {item.get(\"name\", \"?\")}')
login = item.get('login', {})
if login:
    print(f'  Username: {login.get(\"username\", \"-\")}')
    pw = login.get('password', '')
    print(f'  Password: {\"*\" * min(len(pw), 8) if pw else \"-\"}')
    uris = login.get('uris', [])
    for u in uris:
        print(f'  URI:      {u.get(\"uri\", \"\")}')
notes = item.get('notes', '')
if notes:
    print(f'  Notes:    {notes[:100]}')
"
}

cmd_search() {
    local query="$1"
    check_unlocked
    bw list items --search "$query" 2>/dev/null | python3 -c "
import sys, json
items = json.load(sys.stdin)
if not items:
    print('  No results.')
    sys.exit()
for i in items:
    name = i.get('name', '?')
    login = i.get('login', {})
    user = login.get('username', '-') if login else '-'
    uris = login.get('uris', []) if login else []
    uri = uris[0].get('uri', '') if uris else ''
    print(f'  {name}')
    if user != '-':
        print(f'    user: {user}')
    if uri:
        print(f'    uri:  {uri}')
"
}

cmd_list() {
    check_unlocked
    bw list items 2>/dev/null | python3 -c "
import sys, json
items = json.load(sys.stdin)
print(f'  {len(items)} items in vault:')
print()
for i in sorted(items, key=lambda x: x.get('name', '')):
    name = i.get('name', '?')
    print(f'  {name}')
"
}

cmd_sync() {
    check_unlocked
    bw sync 2>/dev/null
    ok "Vault synced."
}

resolve_item_id() {
    local input="$1"
    # If it looks like a UUID, use directly
    if [[ "$input" =~ ^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$ ]]; then
        echo "$input"
        return
    fi
    # Resolve name to ID
    local item_json
    item_json=$(bw get item "$input" 2>/dev/null) || die "Item '$input' not found"
    echo "$item_json" | python3 -c "import sys,json; print(json.load(sys.stdin)['id'])"
}

cmd_create() {
    local name="" username="" password="" url="" folder=""

    # Parse positional args
    [[ $# -lt 3 ]] && die "Usage: vault create <name> <username> <password> [--url URL] [--folder FOLDER]"
    name="$1"; username="$2"; password="$3"
    shift 3

    # Parse optional flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --url)    url="${2:-}"; shift 2 ;;
            --folder) folder="${2:-}"; shift 2 ;;
            *)        die "Unknown option: $1" ;;
        esac
    done

    check_unlocked

    # Resolve folder name to ID if specified
    local folder_id=""
    if [[ -n "$folder" ]]; then
        folder_id=$(FOLDER="$folder" bw list folders 2>/dev/null | python3 -c "
import sys, json, os
folders = json.load(sys.stdin)
target = os.environ['FOLDER'].lower()
for f in folders:
    if f.get('name', '').lower() == target:
        print(f['id'])
        sys.exit()
print('')
") || die "Failed to list folders"
        [[ -z "$folder_id" ]] && die "Folder '$folder' not found"
    fi

    # Get template, modify, encode, create
    local template
    template=$(bw get template item 2>/dev/null) || die "Failed to get item template"

    local encoded
    encoded=$(NAME="$name" USERNAME="$username" PASSWORD="$password" URI="$url" FOLDER_ID="$folder_id" \
        python3 -c "
import sys, json, os, base64
item = json.loads(sys.stdin.read())
item['type'] = 1  # login
item['name'] = os.environ['NAME']
item['login'] = {
    'username': os.environ['USERNAME'],
    'password': os.environ['PASSWORD'],
    'uris': []
}
uri = os.environ.get('URI', '')
if uri:
    item['login']['uris'] = [{'match': 0, 'uri': uri}]
fid = os.environ.get('FOLDER_ID', '')
if fid:
    item['folderId'] = fid
else:
    item['folderId'] = None
print(base64.b64encode(json.dumps(item).encode()).decode())
" <<< "$template") || die "Failed to build item JSON"

    local result
    result=$(echo "$encoded" | bw create item 2>/dev/null) || die "Failed to create item"

    local new_id
    new_id=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin)['id'])" 2>/dev/null || echo "?")

    ok "  Created item: $name (ID: $new_id)"
}

cmd_edit() {
    [[ $# -lt 1 ]] && die "Usage: vault edit <id|name> [--username U] [--password P] [--url URL] [--notes N]"

    local identifier="$1"; shift
    local new_username="_UNSET_" new_password="_UNSET_" new_url="_UNSET_" new_notes="_UNSET_"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --username) new_username="${2:-}"; shift 2 ;;
            --password) new_password="${2:-}"; shift 2 ;;
            --url)      new_url="${2:-}"; shift 2 ;;
            --notes)    new_notes="${2:-}"; shift 2 ;;
            *)          die "Unknown option: $1" ;;
        esac
    done

    # Check at least one field specified
    if [[ "$new_username" == "_UNSET_" && "$new_password" == "_UNSET_" && "$new_url" == "_UNSET_" && "$new_notes" == "_UNSET_" ]]; then
        die "No fields to edit. Use --username, --password, --url, or --notes"
    fi

    check_unlocked

    local item_id
    item_id=$(resolve_item_id "$identifier")

    local item_json
    item_json=$(bw get item "$item_id" 2>/dev/null) || die "Failed to get item '$identifier'"

    local encoded
    encoded=$(EDIT_USERNAME="$new_username" EDIT_PASSWORD="$new_password" EDIT_URL="$new_url" EDIT_NOTES="$new_notes" \
        python3 -c "
import sys, json, os, base64
item = json.load(sys.stdin)
login = item.get('login', {}) or {}

u = os.environ.get('EDIT_USERNAME', '_UNSET_')
if u != '_UNSET_':
    login['username'] = u

p = os.environ.get('EDIT_PASSWORD', '_UNSET_')
if p != '_UNSET_':
    login['password'] = p

url = os.environ.get('EDIT_URL', '_UNSET_')
if url != '_UNSET_':
    login['uris'] = [{'match': 0, 'uri': url}]

item['login'] = login

n = os.environ.get('EDIT_NOTES', '_UNSET_')
if n != '_UNSET_':
    item['notes'] = n

print(base64.b64encode(json.dumps(item).encode()).decode())
" <<< "$item_json") || die "Failed to modify item JSON"

    echo "$encoded" | bw edit item "$item_id" >/dev/null 2>&1 || die "Failed to edit item '$identifier'"

    ok "  Updated item: $identifier"
}

cmd_delete() {
    local identifier="${1:-}"
    [[ -z "$identifier" ]] && die "Usage: vault delete <id|name>"

    check_unlocked

    local item_id
    item_id=$(resolve_item_id "$identifier")

    # Get item name for confirmation message
    local item_name
    item_name=$(bw get item "$item_id" 2>/dev/null | python3 -c "import sys,json; print(json.load(sys.stdin).get('name','?'))" 2>/dev/null || echo "$identifier")

    confirm_action "Delete item '$item_name'?"

    bw delete item "$item_id" 2>/dev/null || die "Failed to delete item '$identifier'"

    ok "  Deleted item: $item_name ($item_id)"
}

cmd_folders() {
    check_unlocked

    local folders_json
    folders_json=$(bw list folders 2>/dev/null) || die "Failed to list folders"

    header "VAULT FOLDERS"

    echo "$folders_json" | python3 -c "
import sys, json
folders = json.load(sys.stdin)
print(f'  Total: {len(folders)} folders\n')
print(f'  {\"(no folder)\":<40} Items without a folder')
print()
print(f'  {\"ID\":<40} {\"Name\"}')
print(f'  {\"─\"*38}   {\"─\"*30}')
for f in sorted(folders, key=lambda x: x.get('name', '')):
    fid = f.get('id', '?')
    name = f.get('name', '?')
    print(f'  {fid:<40} {name}')
"
}

cmd_generate() {
    local length=20
    local charset="-ulns"  # uppercase, lowercase, number, special

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --length)       length="${2:-20}"; shift 2 ;;
            --no-symbols)   charset="-uln"; shift ;;
            --numbers-only) charset="-n"; shift ;;
            *)              die "Unknown option: $1" ;;
        esac
    done

    local pw
    pw=$(bw generate --length "$length" $charset 2>/dev/null) || die "Failed to generate password"
    echo "$pw"
}

cmd_totp() {
    local identifier="${1:-}"
    [[ -z "$identifier" ]] && die "Usage: vault totp <id|name>"

    check_unlocked

    local code
    code=$(bw get totp "$identifier" 2>/dev/null) || die "No TOTP configured for '$identifier'"

    [[ -z "$code" ]] && die "No TOTP configured for '$identifier'"

    local remaining
    remaining=$(python3 -c "import time; print(30 - int(time.time()) % 30)")

    echo -e "  Code:      ${BOLD}${code}${RESET}"
    echo -e "  Expires:   ${remaining}s"
}

cmd_help() {
    show_version "vault"
    cat <<'HELP'
Quick access to Vaultwarden secrets

USAGE:
  vault <command> [args...]

LOOKUP:
  status                Check vault status (locked/unlocked)
  get <name>            Get password by entry name
  user <name>           Get username by entry name
  item <name>           Show full item details
  search <query>        Search entries
  list                  List all entries

ITEM MANAGEMENT:
  create <name> <user> <pass> [--url URL] [--folder FOLDER]
                        Create a new login item
  edit <id|name> [--username U] [--password P] [--url URL] [--notes N]
                        Edit fields on an existing item
  delete|rm <id|name>   Delete an item (with confirmation)

SYNC:
  sync                  Sync vault

EXAMPLES:
  vault status
  vault get "My API Token"
  vault search proxmox
  vault create "New Service" admin s3cret --url https://svc.local
  vault edit "New Service" --password newpass123
  vault delete "Old Service"

NOTE:
  Vault must be unlocked first: bw unlock
  Then export BW_SESSION="..."
HELP
}

# ── Main ─────────────────────────────────────────────────────

main() {
    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        status)         cmd_status ;;
        get|password)   cmd_get "$1" ;;
        user|username)  cmd_user "$1" ;;
        item|show)      cmd_item "$1" ;;
        search|find)    cmd_search "$1" ;;
        list|ls)        cmd_list ;;
        sync)           cmd_sync ;;
        create)         cmd_create "$@" ;;
        edit)           cmd_edit "$@" ;;
        delete|rm)      cmd_delete "$@" ;;
        folders)        cmd_folders ;;
        generate|gen)   cmd_generate "$@" ;;
        totp)           cmd_totp "$@" ;;
        help|--help|-h) cmd_help ;;
        *)
            err "Unknown command: $cmd"
            cmd_help >&2
            exit 1
            ;;
    esac
}

main "$@"
