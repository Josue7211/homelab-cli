#!/usr/bin/env bash
# gluetun - CLI for Gluetun VPN container
# Monitor and control VPN status, public IP, and port forwarding.

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
source "$SCRIPT_DIR/../lib/common.sh"

# ── Defaults (overridden by config) ─────────────────────────────
GLUETUN_URL="${GLUETUN_URL:-http://localhost:8000}"

# ── API helpers ────────────────────────────────────────────────

gluetun_get() {
    local path="$1"
    curl -sf "${GLUETUN_URL}${path}" 2>/dev/null
}

gluetun_put() {
    local path="$1" data="$2"
    curl -sf -X PUT "${GLUETUN_URL}${path}" \
        -H "Content-Type: application/json" \
        -d "$data" 2>/dev/null
}

# ── Commands ───────────────────────────────────────────────────

cmd_status() {
    header "GLUETUN VPN STATUS"

    echo -e "  URL:      ${DIM}${GLUETUN_URL}${RESET}"
    echo ""

    # VPN status
    local vpn_status
    vpn_status=$(gluetun_get "/v1/openvpn/status") || {
        die "Can't connect to Gluetun at ${GLUETUN_URL}"
    }
    echo "$vpn_status" | python3 -c "
import sys, json
d = json.load(sys.stdin)
status = d.get('status', '?')
color = '\033[32m' if status == 'running' else '\033[31m'
print(f'  VPN:       {color}{status}\033[0m')
"

    # Public IP
    local ip
    ip=$(gluetun_get "/v1/publicip/ip") || true
    if [[ -n "$ip" ]]; then
        echo "$ip" | python3 -c "
import sys, json
d = json.load(sys.stdin)
ip = d.get('public_ip', d.get('ip', '?'))
region = d.get('region', '')
country = d.get('country', '')
loc = []
if region: loc.append(region)
if country: loc.append(country)
loc_str = f' ({', '.join(loc)})' if loc else ''
print(f'  Public IP: {ip}{loc_str}')
" 2>/dev/null || echo "  Public IP: (unavailable)"
    else
        echo "  Public IP: (unavailable)"
    fi

    # Forwarded port
    local port
    port=$(gluetun_get "/v1/openvpn/portforwarded") || true
    if [[ -n "$port" ]]; then
        echo "$port" | python3 -c "
import sys, json
d = json.load(sys.stdin)
p = d.get('port', 0)
if p and p > 0:
    print(f'  Forwarded: port {p}')
else:
    print(f'  Forwarded: (none)')
" 2>/dev/null || echo "  Forwarded: (unavailable)"
    else
        echo "  Forwarded: (unavailable)"
    fi
}

cmd_ip() {
    local ip
    ip=$(gluetun_get "/v1/publicip/ip") || die "Can't get public IP"
    echo "$ip" | python3 -c "
import sys, json
d = json.load(sys.stdin)
ip = d.get('public_ip', d.get('ip', '?'))
print(ip)
"
}

cmd_port() {
    local port
    port=$(gluetun_get "/v1/openvpn/portforwarded") || die "Can't get forwarded port"
    echo "$port" | python3 -c "
import sys, json
d = json.load(sys.stdin)
p = d.get('port', 0)
if p and p > 0:
    print(p)
else:
    print('No port forwarded')
    sys.exit(1)
"
}

cmd_stop() {
    local result
    result=$(gluetun_put "/v1/openvpn/status" '{"status": "stopped"}') || die "Failed to stop VPN"
    echo "$result" | python3 -c "
import sys, json
d = json.load(sys.stdin)
status = d.get('outcome', d.get('status', '?'))
print(f'  VPN: {status}')
" 2>/dev/null
    ok "  VPN stopped."
}

cmd_start() {
    local result
    result=$(gluetun_put "/v1/openvpn/status" '{"status": "running"}') || die "Failed to start VPN"
    echo "$result" | python3 -c "
import sys, json
d = json.load(sys.stdin)
status = d.get('outcome', d.get('status', '?'))
print(f'  VPN: {status}')
" 2>/dev/null
    ok "  VPN started."
}

cmd_restart() {
    info "  Stopping VPN..."
    gluetun_put "/v1/openvpn/status" '{"status": "stopped"}' >/dev/null 2>&1 || true
    sleep 2
    info "  Starting VPN..."
    local result
    result=$(gluetun_put "/v1/openvpn/status" '{"status": "running"}') || die "Failed to start VPN"
    echo "$result" | python3 -c "
import sys, json
d = json.load(sys.stdin)
status = d.get('outcome', d.get('status', '?'))
print(f'  VPN: {status}')
" 2>/dev/null
    ok "  VPN restarted."
}

cmd_provider() {
    header "VPN PROVIDER"
    local settings
    settings=$(gluetun_get "/v1/vpn/settings") || die "Can't get VPN settings"
    echo "$settings" | python3 -c "
import sys, json
d = json.load(sys.stdin)
# Navigate nested structure - Gluetun v3 API nests under vpn key
vpn = d.get('vpn', d)
provider = vpn.get('provider', vpn.get('type', '?'))
protocol = vpn.get('type', vpn.get('protocol', '?'))
# Server selection fields
countries = ', '.join(vpn.get('server_countries', [])) or '(any)'
regions = ', '.join(vpn.get('server_regions', [])) or '(any)'
cities = ', '.join(vpn.get('server_cities', [])) or '(any)'
hostnames = ', '.join(vpn.get('server_hostnames', [])) or '(any)'
print(f'  Provider:    {provider}')
print(f'  Protocol:    {protocol}')
print(f'  Countries:   {countries}')
print(f'  Regions:     {regions}')
print(f'  Cities:      {cities}')
print(f'  Hostnames:   {hostnames}')
"
}

cmd_servers() {
    local filter="${1:-}"
    header "AVAILABLE SERVERS"
    local servers
    servers=$(gluetun_get "/v1/servers") || die "Can't get server list"
    echo "$servers" | FILTER="$filter" python3 -c "
import sys, json, os
data = json.load(sys.stdin)
filt = os.environ.get('FILTER', '').lower()
# Gluetun returns servers grouped by provider or as flat list
# Handle both: {provider: [{...}]} or [{...}]
all_servers = []
if isinstance(data, dict):
    for provider, slist in data.items():
        if isinstance(slist, list):
            for s in slist:
                s['_provider'] = provider
                all_servers.append(s)
elif isinstance(data, list):
    all_servers = data

# Filter if specified
if filt:
    matches = []
    for s in all_servers:
        searchable = ' '.join([
            str(s.get('hostname', '')),
            str(s.get('country', '')),
            str(s.get('region', '')),
            str(s.get('city', '')),
        ]).lower()
        if filt in searchable:
            matches.append(s)
    all_servers = matches

if not all_servers:
    print('  No servers found' + (f' matching \"{filt}\"' if filt else ''))
    sys.exit(0)

# Limit to 20 if no filter
limit = len(all_servers) if filt else min(20, len(all_servers))
total = len(all_servers)

# Print table header
print(f'  {\"Hostname\":<40} {\"Country\":<20} {\"Region\":<20} {\"City\":<15}')
print(f'  {\"─\"*40} {\"─\"*20} {\"─\"*20} {\"─\"*15}')
for s in all_servers[:limit]:
    host = s.get('hostname', s.get('server_name', '?'))[:40]
    country = str(s.get('country', '?'))[:20]
    region = str(s.get('region', ''))[:20]
    city = str(s.get('city', ''))[:15]
    print(f'  {host:<40} {country:<20} {region:<20} {city:<15}')

if limit < total:
    print(f'')
    print(f'  Showing {limit} of {total} servers. Use \"gluetun servers <filter>\" to narrow results.')
"
}

cmd_dns() {
    header "DNS CONFIGURATION"
    local dns
    dns=$(gluetun_get "/v1/dns/settings") || die "Can't get DNS settings"
    echo "$dns" | python3 -c "
import sys, json
d = json.load(sys.stdin)
# Handle both nested (dns: {...}) and flat structures
dns = d.get('dns', d)
doh = dns.get('doh', dns)
# Provider info
providers = doh.get('providers', dns.get('providers', []))
if isinstance(providers, list):
    providers = ', '.join(providers) if providers else '(none)'
print(f'  DoH Providers:    {providers}')
# Upstream DNS
addresses = dns.get('addresses', dns.get('server_addresses', []))
if isinstance(addresses, list):
    addresses = ', '.join(addresses) if addresses else '(default)'
print(f'  DNS Addresses:    {addresses}')
# Keep nameserver
keep = dns.get('keep_nameserver', dns.get('keepNameserver', '?'))
print(f'  Keep Nameserver:  {keep}')
# Block lists
block_malicious = dns.get('block_malicious', dns.get('blockMalicious', '?'))
block_surveillance = dns.get('block_surveillance', dns.get('blockSurveillance', '?'))
block_ads = dns.get('block_ads', dns.get('blockAds', '?'))
print(f'  Block Malicious:  {block_malicious}')
print(f'  Block Surveillance: {block_surveillance}')
print(f'  Block Ads:        {block_ads}')
"
}

cmd_ports() {
    header "PORT FORWARDING"
    # Try v1 portforwarding endpoint first
    local ports
    ports=$(gluetun_get "/v1/portforwarding") 2>/dev/null
    if [[ -n "$ports" ]]; then
        echo "$ports" | python3 -c "
import sys, json
d = json.load(sys.stdin)
# Handle various response structures
ports = d.get('ports', d.get('forwarded_ports', []))
if isinstance(ports, list) and ports:
    for p in ports:
        if isinstance(p, dict):
            port_num = p.get('port', p.get('external_port', '?'))
            proto = p.get('protocol', 'tcp+udp')
            print(f'  Port {port_num} ({proto})')
        else:
            print(f'  Port {p}')
elif isinstance(d.get('port', None), int) and d['port'] > 0:
    print(f'  Port {d[\"port\"]}')
else:
    # Try checking if forwarding is just not enabled
    enabled = d.get('enabled', d.get('provider', None))
    if enabled is False or enabled is None:
        print('  Port forwarding not active')
    else:
        print('  No ports currently forwarded')
" 2>/dev/null && return 0
    fi
    # Fallback to legacy endpoint
    local legacy
    legacy=$(gluetun_get "/v1/openvpn/portforwarded") 2>/dev/null
    if [[ -n "$legacy" ]]; then
        echo "$legacy" | python3 -c "
import sys, json
d = json.load(sys.stdin)
p = d.get('port', 0)
if p and p > 0:
    print(f'  Port {p} (forwarded)')
else:
    print('  Port forwarding not active')
"
    else
        echo "  Port forwarding not active"
    fi
}

cmd_help() {
    show_version "gluetun"
    cat <<'HELP'

CLI for Gluetun VPN container.

USAGE:
  gluetun <command>

STATUS:
  status                      VPN status, public IP, and forwarded port
  ip                          Show current public IP
  port                        Show forwarded port
  provider                    VPN provider, protocol, and server selection
  servers [filter]            List available servers (filter by region/country)
  dns                         DNS-over-HTTPS configuration
  ports                       Port forwarding status

CONTROL:
  start                       Start the VPN
  stop                        Stop the VPN
  restart                     Restart the VPN

EXAMPLES:
  gluetun status              Full VPN status overview
  gluetun ip                  Quick IP check
  gluetun provider            Show VPN provider details
  gluetun servers us          List US servers
  gluetun dns                 Show DNS configuration
  gluetun ports               Check forwarded ports
  gluetun restart             Reconnect the VPN
HELP
}

# ── Main ───────────────────────────────────────────────────────

main() {
    require_curl
    require_python

    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        status)             cmd_status ;;
        ip)                 cmd_ip ;;
        port)               cmd_port ;;
        stop)               cmd_stop ;;
        start)              cmd_start ;;
        restart)            cmd_restart ;;
        provider)           cmd_provider ;;
        servers)            cmd_servers "$1" ;;
        dns)                cmd_dns ;;
        ports)              cmd_ports ;;
        help|--help|-h)     cmd_help ;;
        *)
            err "Unknown command: $cmd"
            cmd_help >&2
            exit 1
            ;;
    esac
}

main "$@"
