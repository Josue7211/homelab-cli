#!/usr/bin/env bash
# sab - CLI for SABnzbd Usenet downloader
# Queue management, history, and status via the SABnzbd API.

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
source "$SCRIPT_DIR/../lib/common.sh"

# ── Defaults (overridden by config) ─────────────────────────────
SAB_URL="${SAB_URL:-http://localhost:8090}"
SAB_API_KEY_SOURCE="${SAB_API_KEY_SOURCE:-bw}"
SAB_API_KEY_BW_ENTRY="${SAB_API_KEY_BW_ENTRY:-SABnzbd API Key}"

# ── API key management ─────────────────────────────────────────
_sab_key=""

get_sab_key() {
    if [[ -n "$_sab_key" ]]; then echo "$_sab_key"; return; fi
    local key
    key=$(get_secret "$SAB_API_KEY_SOURCE" "$SAB_API_KEY_BW_ENTRY") || {
        die "Can't get SABnzbd API key. Is vault unlocked? (bw unlock)"
    }
    _sab_key="$key"
    echo "$key"
}

sab_api() {
    local mode="$1"
    shift
    local key
    key=$(get_sab_key)

    local extra=""
    for arg in "$@"; do
        extra="${extra}&${arg}"
    done

    curl -sf "${SAB_URL}/api?apikey=${key}&mode=${mode}&output=json${extra}" 2>/dev/null
}

# ── Commands ───────────────────────────────────────────────────

cmd_status() {
    header "SABNZBD STATUS"

    local version
    version=$(sab_api "version") || die "Can't connect to SABnzbd"
    echo "$version" | python3 -c "
import sys, json
d = json.load(sys.stdin)
print(f'  Version:  {d.get(\"version\", \"?\")}')" 2>/dev/null
    echo -e "  URL:      ${DIM}${SAB_URL}${RESET}"
    echo ""

    local queue
    queue=$(sab_api "queue") || die "Can't get queue"
    echo "$queue" | python3 -c "
import sys, json
d = json.load(sys.stdin).get('queue', {})
status = d.get('status', '?')
speed = d.get('speed', '?')
size_left = d.get('sizeleft', '?')
time_left = d.get('timeleft', '?')
mb_left = d.get('mbleft', '0')
slots = len(d.get('slots', []))
paused = d.get('paused', False)

state_str = f'{status} (paused)' if paused else status
print(f'  Status:    {state_str}')
print(f'  Speed:     {speed}')
print(f'  Remaining: {size_left} ({time_left} left)')
print(f'  Queue:     {slots} items')
"
}

cmd_queue() {
    header "SABNZBD QUEUE"

    local queue
    queue=$(sab_api "queue") || die "Can't get queue"
    echo "$queue" | python3 -c "
import sys, json
d = json.load(sys.stdin).get('queue', {})
slots = d.get('slots', [])
speed = d.get('speed', '?')
size_left = d.get('sizeleft', '?')
time_left = d.get('timeleft', '?')

print(f'  Speed: {speed}  |  Remaining: {size_left}  |  ETA: {time_left}')
print()

if not slots:
    print('  (queue empty)')
    sys.exit()

print(f'  {\"Name\":<50} {\"Size\":>9}  {\"Done\":>5}  {\"Status\":<12} {\"ETA\":>10}')
print(f'  {\"─\"*50} {\"─\"*9}  {\"─\"*5}  {\"─\"*12} {\"─\"*10}')

for s in slots:
    name = s.get('filename', '?')[:50]
    size = s.get('size', '?')
    pct = f'{float(s.get(\"percentage\", 0)):.0f}%'
    status = s.get('status', '?')
    timeleft = s.get('timeleft', '?')
    print(f'  {name:<50} {size:>9}  {pct:>5}  {status:<12} {timeleft:>10}')
"
}

cmd_history() {
    local limit="${1:-20}"
    header "SABNZBD HISTORY (last ${limit})"

    local history
    history=$(sab_api "history" "limit=${limit}") || die "Can't get history"
    echo "$history" | python3 -c "
import sys, json
d = json.load(sys.stdin).get('history', {})
slots = d.get('slots', [])
total = d.get('noofslots', 0)

print(f'  Total history: {total} items (showing {len(slots)})')
print()

if not slots:
    print('  (no history)')
    sys.exit()

def fmt_size(b):
    b = float(b) * 1024 * 1024  # SAB gives MB
    for u in ['MB','GB','TB']:
        if b < 1024: return f'{b:.1f} {u}'
        b /= 1024
    return f'{b:.1f} PB'

print(f'  {\"Name\":<50} {\"Size\":>9}  {\"Status\":<12} {\"Completed\"}')
print(f'  {\"─\"*50} {\"─\"*9}  {\"─\"*12} {\"─\"*19}')

for s in slots:
    name = s.get('name', '?')[:50]
    size = s.get('size', '?')
    status = s.get('status', '?')
    completed = s.get('completed', 0)

    import datetime
    try:
        date = datetime.datetime.fromtimestamp(completed).strftime('%Y-%m-%d %H:%M')
    except:
        date = '?'

    color = '\033[32m' if status == 'Completed' else '\033[31m' if status == 'Failed' else ''
    reset = '\033[0m' if color else ''
    print(f'  {name:<50} {size:>9}  {color}{status:<12}{reset} {date}')
"
}

cmd_pause() {
    sab_api "pause" >/dev/null || die "Failed to pause queue"
    ok "  SABnzbd queue paused."
}

cmd_resume() {
    sab_api "resume" >/dev/null || die "Failed to resume queue"
    ok "  SABnzbd queue resumed."
}

cmd_add() {
    local url="${1:-}"
    [[ -z "$url" ]] && die "Usage: sab add <nzb_url>"

    local result
    result=$(sab_api "addurl" "name=${url}") || die "Failed to add NZB"
    echo "$result" | python3 -c "
import sys, json
d = json.load(sys.stdin)
status = d.get('status', False)
if status:
    print('  NZB added successfully.')
else:
    print(f'  Failed: {d.get(\"error\", \"unknown error\")}')
    sys.exit(1)
"
}

cmd_speed() {
    local queue
    queue=$(sab_api "queue") || die "Can't get queue"
    echo "$queue" | python3 -c "
import sys, json
d = json.load(sys.stdin).get('queue', {})
speed = d.get('speed', '?')
print(f'  Download: {speed}')
"
}

cmd_info() {
    local nzo_id="${1:-}"
    [[ -z "$nzo_id" ]] && die "Usage: sab info <nzo_id>"
    header "NZB DETAIL"
    local queue
    queue=$(sab_api "queue") || die "Can't get queue"
    echo "$queue" | NZO_ID="$nzo_id" python3 -c "
import sys, json, os
nzo = os.environ['NZO_ID']
d = json.load(sys.stdin).get('queue', {})
match = None
for s in d.get('slots', []):
    if s.get('nzo_id') == nzo:
        match = s; break
if not match:
    print(f'  Item not found in queue: {nzo}')
    sys.exit(1)
s = match
prio_map = {'-100': 'Stop', '-1': 'Low', '0': 'Normal', '1': 'High', '2': 'Force'}
prio = prio_map.get(str(s.get('priority', 0)), str(s.get('priority', '?')))
print(f'  Filename:    {s.get(\"filename\", \"?\")}')
print(f'  NZO ID:      {s.get(\"nzo_id\", \"?\")}')
print(f'  Status:      {s.get(\"status\", \"?\")}')
print(f'  Category:    {s.get(\"cat\", \"*\")}')
print(f'  Priority:    {prio}')
print(f'  Size:        {s.get(\"size\", \"?\")}')
print(f'  Downloaded:  {s.get(\"mb\", \"?\")} MB')
print(f'  Remaining:   {s.get(\"sizeleft\", \"?\")}')
print(f'  Progress:    {s.get(\"percentage\", \"?\")}%')
print(f'  ETA:         {s.get(\"timeleft\", \"?\")}')
print(f'  Age:         {s.get(\"avg_age\", \"?\")}')
print(f'  Script:      {s.get(\"script\", \"Default\")}')
print(f'  Unpack:      {s.get(\"unpackopts\", \"?\")}')
"
}

cmd_delete() {
    local nzo_id="${1:-}"
    [[ -z "$nzo_id" ]] && die "Usage: sab delete <nzo_id> [--del-files]"
    local del_files=0
    [[ "${2:-}" == "--del-files" ]] && del_files=1
    confirm_action "Delete item '$nzo_id' from queue?"
    local result
    if [[ "$del_files" -eq 1 ]]; then
        result=$(sab_api "queue" "name=delete" "value=$nzo_id" "del_files=1") || die "Failed to delete item: $nzo_id"
    else
        result=$(sab_api "queue" "name=delete" "value=$nzo_id") || die "Failed to delete item: $nzo_id"
    fi
    echo "$result" | python3 -c "
import sys, json
d = json.load(sys.stdin)
if d.get('status'):
    pass
else:
    print(f'  Error: {d.get(\"error\", \"unknown\")}')
    sys.exit(1)
" || die "Failed to delete item: $nzo_id"
    ok "  Deleted from queue: $nzo_id"
}

cmd_pause_item() {
    local nzo_id="${1:-}"
    [[ -z "$nzo_id" ]] && die "Usage: sab pause-item <nzo_id>"
    sab_api "queue" "name=pause" "value=$nzo_id" >/dev/null || die "Failed to pause item: $nzo_id"
    ok "  Paused: $nzo_id"
}

cmd_resume_item() {
    local nzo_id="${1:-}"
    [[ -z "$nzo_id" ]] && die "Usage: sab resume-item <nzo_id>"
    sab_api "queue" "name=resume" "value=$nzo_id" >/dev/null || die "Failed to resume item: $nzo_id"
    ok "  Resumed: $nzo_id"
}

cmd_priority() {
    local nzo_id="${1:-}"
    local level="${2:-}"
    [[ -z "$nzo_id" || -z "$level" ]] && die "Usage: sab priority <nzo_id> <stop|low|normal|high|force>"
    local numeric
    case "$level" in
        stop)    numeric="-100" ;;
        low)     numeric="-1" ;;
        normal)  numeric="0" ;;
        high)    numeric="1" ;;
        force)   numeric="2" ;;
        -100|-1|0|1|2) numeric="$level" ;;
        *)       die "Invalid priority: $level (use: stop, low, normal, high, force)" ;;
    esac
    sab_api "queue" "name=priority" "value=$nzo_id" "value2=$numeric" >/dev/null || die "Failed to set priority"
    ok "  Priority set to $level for $nzo_id"
}

cmd_categories() {
    header "CATEGORIES"
    local result
    result=$(sab_api "get_cats") || die "Can't get categories"
    echo "$result" | python3 -c "
import sys, json
d = json.load(sys.stdin)
cats = d.get('categories', [])
if not cats:
    print('  No categories configured.')
    sys.exit()
for c in cats:
    marker = ' (default)' if c == '*' else ''
    print(f'  {c}{marker}')
print(f'\n  Total: {len(cats)} categories')
"
}

cmd_limit() {
    local speed="${1:-}"
    if [[ -z "$speed" ]]; then
        # Show current limit
        local queue
        queue=$(sab_api "queue") || die "Can't get queue"
        echo "$queue" | python3 -c "
import sys, json
d = json.load(sys.stdin).get('queue', {})
limit = d.get('speedlimit', '0')
speed = d.get('speed', '?')
kbspeed = d.get('kbpersec', '0')
limit_str = f'{limit} KB/s' if limit and str(limit) != '0' else 'Unlimited'
print(f'  Speed Limit:    {limit_str}')
print(f'  Current Speed:  {speed}')
"
    else
        sab_api "config" "name=speedlimit" "value=$speed" >/dev/null || die "Failed to set speed limit"
        if [[ "$speed" == *% ]]; then
            ok "  Speed limit set to: $speed"
        elif [[ "$speed" == "0" ]]; then
            ok "  Speed limit removed (unlimited)."
        else
            ok "  Speed limit set to: ${speed} KB/s"
        fi
    fi
}

cmd_servers() {
    header "NEWS SERVERS"
    local result
    result=$(sab_api "get_config" "section=servers") || die "Can't get server config"
    echo "$result" | python3 -c "
import sys, json
d = json.load(sys.stdin)
servers = d.get('config', {}).get('servers', [])
if not servers:
    print('  No servers configured.')
    sys.exit()
print(f'  {\"Name\":<25} {\"Host\":<30} {\"Port\":>5}  {\"SSL\":>3}  {\"Conn\":>4}  {\"Prio\":>4}  {\"Enabled\"}')
print(f'  {\"─\"*24} {\"─\"*29} {\"─\"*5}  {\"─\"*3}  {\"─\"*4}  {\"─\"*4}  {\"─\"*7}')
for s in servers:
    name = s.get('displayname', s.get('host', '?'))[:24]
    host = s.get('host', '?')[:29]
    port = s.get('port', '?')
    ssl = 'Yes' if s.get('ssl', 0) else 'No'
    conn = s.get('connections', '?')
    prio = s.get('priority', '?')
    enabled = 'Yes' if s.get('enable', 0) else 'No'
    print(f'  {name:<25} {host:<30} {port:>5}  {ssl:>3}  {conn:>4}  {prio:>4}  {enabled}')
print(f'\n  Total: {len(servers)} servers')
"
}

cmd_help() {
    show_version "sab"
    cat <<'HELP'

CLI for SABnzbd Usenet downloader.

USAGE:
  sab <command> [args...]

STATUS:
  status                      Version, queue summary, and speed
  speed                       Current download speed

QUEUE:
  queue                       Show current download queue
  history [count]             Download history (default: 20)
  add <nzb_url>               Add NZB by URL
  pause                       Pause the entire queue
  resume                      Resume the entire queue

QUEUE MANAGEMENT:
  info <nzo_id>               Detailed info for a queue item
  delete <nzo_id> [--del-files]  Remove item from queue
  pause-item <nzo_id>         Pause a single queue item
  resume-item <nzo_id>        Resume a paused queue item
  priority <nzo_id> <level>   Set item priority (stop/low/normal/high/force)

EXAMPLES:
  sab status
  sab queue                   Show active downloads
  sab history 50              Show last 50 completed downloads
  sab pause                   Pause all downloads
  sab resume                  Resume downloading
  sab speed                   Check current speed
  sab add "https://..."       Add NZB by URL
  sab info SABnzbd_nzo_abc    Show details for a queue item
  sab delete SABnzbd_nzo_abc  Remove item (with confirmation)
  sab priority SABnzbd_nzo_abc high  Set item to high priority
HELP
}

# ── Main ───────────────────────────────────────────────────────

main() {
    require_curl
    require_python

    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        status)             cmd_status ;;
        queue|q)            cmd_queue ;;
        history|hist|h)     cmd_history "${1:-20}" ;;
        add)                cmd_add "$@" ;;
        pause)              cmd_pause ;;
        resume)             cmd_resume ;;
        speed)              cmd_speed ;;
        info|detail)        cmd_info "$1" ;;
        delete|rm)          cmd_delete "$@" ;;
        pause-item)         cmd_pause_item "$1" ;;
        resume-item)        cmd_resume_item "$1" ;;
        priority|prio)      cmd_priority "$@" ;;
        categories|cats)    cmd_categories ;;
        limit)              cmd_limit "${1:-}" ;;
        servers)            cmd_servers ;;
        help|--help|-h)     cmd_help ;;
        *)
            err "Unknown command: $cmd"
            cmd_help >&2
            exit 1
            ;;
    esac
}

main "$@"
