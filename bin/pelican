print(f'  {\"ID\":<5} {\"Name\":<20} {\"FQDN\":<25} {\"Memory\":>8} {\"Disk\":>8} {\"Scheme\"}')
print(f'  {\"─\"*4} {\"─\"*19} {\"─\"*24} {\"─\"*8} {\"─\"*8} {\"─\"*6}')
for n in nodes:
