#!/usr/bin/env bash
# pelican - CLI for Pelican Panel (game server management)
# Uses Pelican REST API with Bearer token auth.

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
source "$SCRIPT_DIR/../lib/common.sh"

# ── Config (from ~/.config/homelab-cli/config) ────────────────
PELICAN_URL="${PELICAN_URL:-http://127.0.0.1:8080}"
PELICAN_TOKEN_SOURCE="${PELICAN_TOKEN_SOURCE:-bw}"
PELICAN_TOKEN_BW_ENTRY="${PELICAN_TOKEN_BW_ENTRY:-Pelican API}"

# Cloudflare Access Service Token (bypasses SSO for API calls)
CF_ACCESS_CLIENT_ID="${PELICAN_CF_CLIENT_ID:-b5bdef6a8df19ce70ea3e0f7461b1b85.access}"
CF_ACCESS_CLIENT_SECRET="${PELICAN_CF_CLIENT_SECRET:-57b0e726ba1c00cf44f430e0398ef46724238f276973b55fdcc347cd5a748242}"

# ── Token cache ───────────────────────────────────────────────
_pelican_token=""

get_token() {
    if [[ -n "$_pelican_token" ]]; then echo "$_pelican_token"; return; fi
    _pelican_token=$(get_secret "$PELICAN_TOKEN_SOURCE" "$PELICAN_TOKEN_BW_ENTRY") || {
        die "Can't get Pelican API token. Is vault unlocked? (bw unlock)"
    }
    echo "$_pelican_token"
}

# ── API helpers (Bearer token + Pterodactyl Accept header) ────
pel_api() {
    local method="$1" path="$2"
    shift 2
    local token
    token=$(get_token)
    curl -sf -X "$method" "${PELICAN_URL}/api${path}" \
        -H "Authorization: Bearer $token" \
        -H "Accept: application/vnd.pterodactyl.v1+json" \
        -H "Content-Type: application/json" \
        -H "CF-Access-Client-Id: $CF_ACCESS_CLIENT_ID" \
        -H "CF-Access-Client-Secret: $CF_ACCESS_CLIENT_SECRET" \
        "$@"
}

pel_get()    { pel_api GET "$1"; }
pel_post()   { pel_api POST "$1" "${@:2}"; }
pel_patch()  { pel_api PATCH "$1" "${@:2}"; }
pel_delete() { pel_api DELETE "$1"; }

# ── Commands: Status ──────────────────────────────────────────

cmd_status() {
    header "PELICAN PANEL STATUS"
    echo -e "  URL:  ${DIM}${PELICAN_URL}${RESET}"

    # Nodes
    local nodes
    nodes=$(pel_get "/application/nodes" 2>/dev/null) || { warn "  Can't connect to Panel"; return 1; }
    echo ""
    echo "$nodes" | python3 -c "
import sys, json
d = json.load(sys.stdin)
nodes = d.get('data', [])
print(f'  NODES ({len(nodes)})')
print('  ─────────────────────────────────────────────────────')
for n in nodes:
    a = n.get('attributes', {})
    name = a.get('name', '?')
    fqdn = a.get('fqdn', '?')
    mem = a.get('memory', 0)
    disk = a.get('disk', 0)
    scheme = a.get('scheme', 'https')
    port = a.get('daemon_listen', 8443)
    print(f'    {name:<20} {fqdn}:{port} ({scheme})')
    print(f'    {\" \"*20} Memory: {mem}MB  Disk: {disk}MB')
"

    # Servers
    local servers
    servers=$(pel_get "/application/servers" 2>/dev/null)
    echo ""
    echo "$servers" | python3 -c "
import sys, json
d = json.load(sys.stdin)
servers = d.get('data', [])
print(f'  SERVERS ({len(servers)})')
print('  ─────────────────────────────────────────────────────')
if not servers:
    print('    (no servers)')
else:
    for s in servers:
        a = s.get('attributes', {})
        name = a.get('name', '?')
        status = a.get('status', '?')
        suspended = a.get('suspended', False)
        mem = a.get('limits', {}).get('memory', 0)
        disk = a.get('limits', {}).get('disk', 0)
        cpu = a.get('limits', {}).get('cpu', 0)
        uuid = a.get('uuid', '?')[:8]
        state = 'SUSPENDED' if suspended else status
        print(f'    {name:<25} [{state}]  CPU:{cpu}% Mem:{mem}MB Disk:{disk}MB  ({uuid})')
"
}

# ── Commands: Servers ─────────────────────────────────────────

cmd_servers() {
    pel_get "/application/servers" | python3 -c "
import sys, json
d = json.load(sys.stdin)
servers = d.get('data', [])
if not servers:
    print('  No servers.')
    sys.exit()
print(f'  {\"ID\":<5} {\"Name\":<25} {\"Status\":<12} {\"CPU\":>5} {\"Mem\":>7} {\"Disk\":>7}  {\"UUID\"}')
print(f'  {\"─\"*4} {\"─\"*24} {\"─\"*11} {\"─\"*5} {\"─\"*7} {\"─\"*7}  {\"─\"*36}')
for s in sorted(servers, key=lambda x: x['attributes']['id']):
    a = s['attributes']
    sid = a.get('id', '?')
    name = a.get('name', '?')[:24]
    status = 'SUSPENDED' if a.get('suspended') else a.get('status', '?')
    lim = a.get('limits', {})
    cpu = f'{lim.get(\"cpu\", 0)}%'
    mem = f'{lim.get(\"memory\", 0)}MB'
    disk = f'{lim.get(\"disk\", 0)}MB'
    uuid = a.get('uuid', '?')
    print(f'  {sid:<5} {name:<25} {status:<12} {cpu:>5} {mem:>7} {disk:>7}  {uuid}')
"
}

cmd_server() {
    local identifier="$1"
    [[ -z "$identifier" ]] && die "Usage: pelican server <id|uuid>"

    # Try application API by numeric ID first, then by UUID
    local response
    if [[ "$identifier" =~ ^[0-9]+$ ]]; then
        response=$(pel_get "/application/servers/$identifier?include=allocations,node")
    else
        # Search by identifier/uuid via client API
        response=$(pel_get "/client/servers/$identifier")
    fi

    echo "$response" | python3 -c "
import sys, json
d = json.load(sys.stdin)
a = d.get('attributes', d)
lim = a.get('limits', {})
feat = a.get('feature_limits', {})

print(f'  Name:        {a.get(\"name\", \"?\")}')
print(f'  Description: {a.get(\"description\", \"-\") or \"-\"}')
print(f'  UUID:        {a.get(\"uuid\", \"?\")}')
print(f'  Identifier:  {a.get(\"identifier\", \"?\")}')
print(f'  Status:      {\"SUSPENDED\" if a.get(\"suspended\") else a.get(\"status\", \"?\")}')
print(f'  Node:        {a.get(\"node\", \"?\")}')
print()
print('  LIMITS:')
print(f'    CPU:       {lim.get(\"cpu\", 0)}%')
print(f'    Memory:    {lim.get(\"memory\", 0)} MB')
print(f'    Disk:      {lim.get(\"disk\", 0)} MB')
print(f'    Swap:      {lim.get(\"swap\", 0)} MB')
print(f'    IO:        {lim.get(\"io\", 500)}')
print()
print('  FEATURES:')
print(f'    Databases:   {feat.get(\"databases\", 0)}')
print(f'    Backups:     {feat.get(\"backups\", 0)}')
print(f'    Allocations: {feat.get(\"allocations\", 0)}')

# Allocations
allocs = a.get('relationships', {}).get('allocations', {}).get('data', [])
if allocs:
    print()
    print('  ALLOCATIONS:')
    for al in allocs:
        aa = al.get('attributes', {})
        ip = aa.get('ip', '?')
        port = aa.get('port', '?')
        alias = aa.get('ip_alias', '') or ''
        primary = ' (primary)' if aa.get('assigned') else ''
        print(f'    {ip}:{port}{\" → \" + alias if alias else \"\"}{primary}')
"
}

cmd_resources() {
    local identifier="$1"
    [[ -z "$identifier" ]] && die "Usage: pelican resources <server_identifier>"

    pel_get "/client/servers/$identifier/resources" | python3 -c "
import sys, json
d = json.load(sys.stdin)
a = d.get('attributes', {})
state = a.get('current_state', '?')

def fmt(b):
    for u in ['B','KB','MB','GB']:
        if b < 1024: return f'{b:.1f} {u}'
        b /= 1024
    return f'{b:.1f} TB'

mem = a.get('resources', {}).get('memory_bytes', 0)
mem_lim = a.get('resources', {}).get('memory_limit_bytes', 0)
cpu = a.get('resources', {}).get('cpu_absolute', 0)
disk = a.get('resources', {}).get('disk_bytes', 0)
net_rx = a.get('resources', {}).get('network_rx_bytes', 0)
net_tx = a.get('resources', {}).get('network_tx_bytes', 0)
uptime = a.get('resources', {}).get('uptime', 0)

hours = uptime // 3600
minutes = (uptime % 3600) // 60

state_color = '\033[32m' if state == 'running' else '\033[31m' if state == 'offline' else '\033[33m'
print(f'  State:    {state_color}{state}\033[0m')
print(f'  Uptime:   {hours}h {minutes}m')
print(f'  CPU:      {cpu:.1f}%')
print(f'  Memory:   {fmt(mem)} / {fmt(mem_lim)}')
print(f'  Disk:     {fmt(disk)}')
print(f'  Network:  ↓ {fmt(net_rx)}  ↑ {fmt(net_tx)}')
"
}

# ── Commands: Power ───────────────────────────────────────────

cmd_power() {
    local identifier="$1" signal="$2"
    [[ -z "$identifier" || -z "$signal" ]] && die "Usage: pelican <start|stop|restart|kill> <server_identifier>"

    case "$signal" in
        start|stop|restart|kill) ;;
        *) die "Invalid signal: $signal (expected: start, stop, restart, kill)" ;;
    esac

    info "Sending '$signal' to $identifier..."
    pel_post "/client/servers/$identifier/power" -d "{\"signal\":\"$signal\"}" > /dev/null
    ok "Done."
}

cmd_command() {
    local identifier="$1"
    shift || die "Usage: pelican command <server_identifier> <command...>"
    local cmd="$*"
    [[ -z "$cmd" ]] && die "Usage: pelican command <server_identifier> <command...>"

    pel_post "/client/servers/$identifier/command" \
        -d "$(CMD="$cmd" python3 -c "import json,os; print(json.dumps({'command': os.environ['CMD']}))")" > /dev/null
    ok "  Sent: $cmd"
}

