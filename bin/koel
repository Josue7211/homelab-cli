#!/usr/bin/env bash
# koel - CLI for managing a Koel music server
# Quick deploy, artisan, logs, and status.

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
source "$SCRIPT_DIR/../lib/common.sh"

# ── Config (loaded from ~/.config/homelab-cli/config) ────────
KOEL_URL="${KOEL_URL:-http://localhost:8000}"
KOEL_SSH="${KOEL_SSH_HOST:?Set KOEL_SSH_HOST in config}"
KOEL_CONTAINER="${KOEL_CONTAINER:-koel}"
KOEL_DB_CONTAINER="${KOEL_DB_CONTAINER:-koel-db}"
KOEL_DB_USER="${KOEL_DB_USER:-koel}"
KOEL_DB_NAME="${KOEL_DB_NAME:-koel}"

# API auth config
KOEL_EMAIL="${KOEL_EMAIL:-}"
KOEL_PASS="${KOEL_PASS:-}"
KOEL_TOKEN_FILE="${HOME}/.cache/homelab-cli/koel-token"

# ── API Helpers ──────────────────────────────────────────────

koel_login() {
    [[ -z "$KOEL_EMAIL" || -z "$KOEL_PASS" ]] && \
        die "Set KOEL_EMAIL and KOEL_PASS in ~/.config/homelab-cli/config"

    local body
    body=$(KOEL_EMAIL="$KOEL_EMAIL" KOEL_PASS="$KOEL_PASS" python3 -c \
        "import json,os; print(json.dumps({'email':os.environ['KOEL_EMAIL'],'password':os.environ['KOEL_PASS']}))")

    local resp token
    resp=$(curl -sf -X POST "${KOEL_URL}/api/me" \
        -H "Content-Type: application/json" \
        -d "$body" 2>/dev/null) || die "Koel login failed — check KOEL_URL, KOEL_EMAIL, KOEL_PASS"

    token=$(echo "$resp" | python3 -c "import sys,json; print(json.load(sys.stdin)['token'])" 2>/dev/null) \
        || die "Koel login response missing token"

    mkdir -p "$(dirname "$KOEL_TOKEN_FILE")"
    echo "$token" > "$KOEL_TOKEN_FILE"
    echo "$token"
}

koel_token() {
    if [[ -f "$KOEL_TOKEN_FILE" ]] && find "$KOEL_TOKEN_FILE" -mmin -1440 2>/dev/null | grep -q .; then
        cat "$KOEL_TOKEN_FILE"
        return
    fi
    koel_login
}

koel_api() {
    local method="$1" path="$2" data="${3:-}"
    local url="${KOEL_URL}${path}"
    local token
    token=$(koel_token)

    case "$method" in
        GET)
            curl -sf "$url" \
                -H "Authorization: Bearer ${token}" \
                2>/dev/null
            ;;
        POST)
            if [[ -n "$data" ]]; then
                curl -sf -X POST "$url" \
                    -H "Authorization: Bearer ${token}" \
                    -H "Content-Type: application/json" \
                    -d "$data" \
                    2>/dev/null
            else
                curl -sf -X POST "$url" \
                    -H "Authorization: Bearer ${token}" \
                    -H "Content-Type: application/json" \
                    2>/dev/null
            fi
            ;;
        DELETE)
            curl -sf -X DELETE "$url" \
                -H "Authorization: Bearer ${token}" \
                2>/dev/null
            ;;
    esac
}

# ── Commands ─────────────────────────────────────────────────

cmd_status() {
    header "KOEL STATUS"

    # Web health
    local code
    code=$(curl -so /dev/null -w "%{http_code}" --connect-timeout 3 "$KOEL_URL" 2>/dev/null || echo "000")
    if [[ "$code" =~ ^(200|301|302)$ ]]; then
        ok "    Web:       $KOEL_URL (HTTP $code) OK"
    else
        err "    Web:       $KOEL_URL (HTTP $code) DOWN"
    fi

    # Container status via portainer
    portainer containers plex 2>/dev/null | grep -E "koel" || warn "    (can't check containers -- vault locked?)"

    echo ""
    info "  Quick commands:"
    echo "    koel logs [n]     -- last n lines of koel logs"
    echo "    koel artisan ...  -- run artisan command in container"
    echo "    koel deploy       -- redeploy the music stack"
    echo "    koel shell        -- SSH into the Plex VM"
    echo "    koel db           -- connect to MariaDB CLI"
}

cmd_logs() {
    local tail="${1:-100}"
    portainer logs plex "$KOEL_CONTAINER" "$tail"
}

cmd_db_logs() {
    local tail="${1:-50}"
    portainer logs plex "$KOEL_DB_CONTAINER" "$tail"
}

cmd_artisan() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: koel artisan <command> [args...]"
        echo "Examples:"
        echo "  koel artisan migrate --force"
        echo "  koel artisan tinker"
        echo "  koel artisan koel:scan"
        echo "  koel artisan route:list"
        exit 1
    fi
    ssh "$KOEL_SSH" "docker exec -t $KOEL_CONTAINER php artisan $*"
}

cmd_shell() {
    info "Connecting to Plex VM via $KOEL_SSH..."
    ssh "$KOEL_SSH"
}

cmd_bash() {
    info "Opening shell in $KOEL_CONTAINER container..."
    ssh -t "$KOEL_SSH" "docker exec -it $KOEL_CONTAINER bash"
}

cmd_db() {
    info "Connecting to Koel MariaDB..."
    ssh -t "$KOEL_SSH" "docker exec -it $KOEL_DB_CONTAINER mysql -u ${KOEL_DB_USER} -p ${KOEL_DB_NAME}"
}

cmd_deploy() {
    info "Redeploying music stack on Plex VM..."
    portainer redeploy plex music
}

cmd_restart() {
    info "Restarting $KOEL_CONTAINER container..."
    portainer restart plex "$KOEL_CONTAINER"
}

cmd_scan() {
    info "Scanning music library..."
    ssh "$KOEL_SSH" "docker exec -t $KOEL_CONTAINER php artisan koel:scan"
}

cmd_env() {
    portainer env plex music
}

cmd_compose() {
    portainer compose plex music
}

cmd_open() {
    info "Opening $KOEL_URL in browser..."
    xdg-open "$KOEL_URL" 2>/dev/null || echo "Open: $KOEL_URL"
}

cmd_search() {
    [[ $# -lt 1 ]] && die "Usage: koel search <query>"
    local query="$*"
    local encoded
    encoded=$(QUERY="$query" python3 -c "import urllib.parse,os; print(urllib.parse.quote(os.environ['QUERY']))")

    local resp
    resp=$(koel_api GET "/api/search?q=${encoded}") || die "Search failed"

    echo "$resp" | python3 -c "
import sys, json

data = json.load(sys.stdin)
songs = data.get('songs', [])
albums = data.get('albums', [])
artists = data.get('artists', [])

print()
print('  \033[1mSONGS\033[0m')
print('  ' + chr(0x2500)*55)
if songs:
    for s in songs:
        dur = s.get('length', 0) or 0
        m, sec = divmod(int(dur), 60)
        title = s.get('title', '?')
        artist = s.get('artist_name', s.get('artist', {}).get('name', '?'))
        album = s.get('album_name', s.get('album', {}).get('name', '?'))
        print(f'  {title} | {artist} | {album} | {m}:{sec:02d}')
else:
    print('  (none)')

print()
print('  \033[1mALBUMS\033[0m')
print('  ' + chr(0x2500)*55)
if albums:
    for a in albums:
        name = a.get('name', '?')
        artist = a.get('artist_name', a.get('artist', {}).get('name', '?'))
        year = a.get('created_at', '?')[:4] if a.get('created_at') else '-'
        print(f'  {name} | {artist} | {year}')
else:
    print('  (none)')

print()
print('  \033[1mARTISTS\033[0m')
print('  ' + chr(0x2500)*55)
if artists:
    for ar in artists:
        print(f\"  {ar.get('name', '?')}\")
else:
    print('  (none)')
print()
"
}

cmd_playlists() {
    local resp
    resp=$(koel_api GET "/api/playlist") || die "Failed to fetch playlists"

    echo "$resp" | python3 -c "
import sys, json

data = json.load(sys.stdin)
print()
print('  \033[1mPLAYLISTS\033[0m')
print('  ' + chr(0x2500)*55)
if not data:
    print('  (none)')
else:
    print('  ID | Name | Songs | Owner')
    print('  ' + chr(0x2500)*55)
    for p in data:
        pid = p.get('id', '?')
        name = p.get('name', '?')
        songs = len(p.get('songs', []))
        owner = p.get('user', {}).get('name', '-') if isinstance(p.get('user'), dict) else p.get('owner', {}).get('name', '-') if isinstance(p.get('owner'), dict) else '-'
        print(f'  {pid} | {name} | {songs} | {owner}')
print()
" | format_table
}

cmd_recent() {
    local resp
    resp=$(koel_api GET "/api/interaction/recently-played") || die "Failed to fetch recently played"

    echo "$resp" | python3 -c "
import sys, json

data = json.load(sys.stdin)
print()
print('  \033[1mRECENTLY PLAYED\033[0m')
print('  ' + chr(0x2500)*55)

items = data[:20] if isinstance(data, list) else []
if not items:
    print('  (none)')
else:
    for item in items:
        # Handle both song objects and nested structures
        if isinstance(item, dict):
            title = item.get('title', item.get('song', {}).get('title', '?'))
            artist = item.get('artist_name', item.get('artist', {}).get('name', '?'))
            if artist == '?':
                song = item.get('song', {})
                artist = song.get('artist_name', song.get('artist', {}).get('name', '?'))
            album = item.get('album_name', item.get('album', {}).get('name', '?'))
            if album == '?':
                song = item.get('song', {})
                album = song.get('album_name', song.get('album', {}).get('name', '?'))
            played = item.get('played_at', item.get('updated_at', item.get('created_at', '-')))
            if played and played != '-':
                played = played.replace('T', ' ')[:19]
            print(f'  {title} | {artist} | {album} | {played}')
        else:
            print(f'  Song ID: {item}')
print()
"
}

cmd_stats() {
    local resp
    resp=$(koel_api GET "/api/data") || die "Failed to fetch library data"

    echo "$resp" | python3 -c "
import sys, json

data = json.load(sys.stdin)

# Adapt to response shape: top-level arrays or nested under keys
songs = data.get('songs', []) if isinstance(data, dict) else []
albums = data.get('albums', []) if isinstance(data, dict) else []
artists = data.get('artists', []) if isinstance(data, dict) else []

# If nested under currentUser or similar
if not songs and isinstance(data, dict):
    for key in data:
        val = data[key]
        if isinstance(val, dict):
            songs = songs or val.get('songs', [])
            albums = albums or val.get('albums', [])
            artists = artists or val.get('artists', [])

song_count = len(songs)
album_count = len(albums)
artist_count = len(artists)

# Total duration from song lengths
total_seconds = 0
for s in songs:
    length = s.get('length', 0) or 0
    total_seconds += int(float(length))

hours = total_seconds // 3600
minutes = (total_seconds % 3600) // 60

print()
print('  \033[1mLIBRARY STATS\033[0m')
print('  ' + chr(0x2500)*40)
print(f'  Songs:     {song_count:,}')
print(f'  Albums:    {album_count:,}')
print(f'  Artists:   {artist_count:,}')
print(f'  Duration:  {hours} hours {minutes} minutes')

# File size if available
total_size = 0
has_size = False
for s in songs:
    sz = s.get('size', 0)
    if sz:
        has_size = True
        total_size += int(sz)

if has_size and total_size > 0:
    b = total_size
    for u in ['B','KB','MB','GB','TB']:
        if b < 1024:
            print(f'  Size:      {b:.1f} {u}')
            break
        b /= 1024
print()
"
}

cmd_albums() {
    local artist="$*"
    local resp
    resp=$(koel_api GET "/api/album") || die "Failed to fetch albums"

    ARTIST_FILTER="$artist" python3 -c "
import sys, json, os

data = json.loads(sys.stdin.read())
albums = data if isinstance(data, list) else data.get('albums', data.get('data', []))
artist_filter = os.environ.get('ARTIST_FILTER', '').strip().lower()

results = []
for a in albums:
    name = a.get('name', a.get('title', '?'))
    artist_name = a.get('artist_name', '')
    if not artist_name and isinstance(a.get('artist'), dict):
        artist_name = a['artist'].get('name', '?')
    if not artist_name:
        artist_name = '?'

    if artist_filter and artist_filter not in artist_name.lower():
        continue

    year = '-'
    if a.get('created_at'):
        year = str(a['created_at'])[:4]

    song_count = a.get('song_count', 0)
    if not song_count and isinstance(a.get('songs'), list):
        song_count = len(a['songs'])

    results.append((artist_name, name, year, song_count))

results.sort(key=lambda x: (x[0].lower(), x[1].lower()))

print()
print('  \033[1mALBUMS\033[0m')
print('  ' + chr(0x2500)*55)
print('  Title | Artist | Year | Songs')
print('  ' + chr(0x2500)*55)
for artist_name, name, year, song_count in results:
    print(f'  {name} | {artist_name} | {year} | {song_count}')
print()
print(f'  {len(results)} albums')
print()
" <<< "$resp" | format_table
}

cmd_artists() {
    local resp
    resp=$(koel_api GET "/api/artist") || die "Failed to fetch artists"

    echo "$resp" | python3 -c "
import sys, json

data = json.load(sys.stdin)
artists = data if isinstance(data, list) else data.get('artists', data.get('data', []))

results = []
for a in artists:
    name = a.get('name', '?')
    album_count = a.get('album_count', 0)
    if not album_count and isinstance(a.get('albums'), list):
        album_count = len(a['albums'])
    song_count = a.get('song_count', 0)
    if not song_count and isinstance(a.get('songs'), list):
        song_count = len(a['songs'])
    results.append((name, album_count, song_count))

results.sort(key=lambda x: x[0].lower())

print()
print('  \033[1mARTISTS\033[0m')
print('  ' + chr(0x2500)*55)
print('  Name | Albums | Songs')
print('  ' + chr(0x2500)*55)
for name, album_count, song_count in results:
    print(f'  {name} | {album_count} | {song_count}')
print()
print(f'  {len(results)} artists')
print()
" | format_table
}

cmd_help() {
    show_version "koel"
    cat <<'HELP'
CLI for the Koel music server (Plex VM)

USAGE:
  koel <command> [args...]

STATUS:
  status                Show Koel health and container status
  open                  Open Koel in browser

LIBRARY:
  search <query>        Search songs, albums, and artists
  playlists             List all playlists
  recent                Show recently played tracks
  stats                 Show library statistics
  albums [artist]       Browse albums (optionally filter by artist)
  artists               List all artists

DEPLOYMENT:
  deploy                Redeploy the music stack (pull images + prune)
  restart               Restart the koel container
  compose               Show the docker-compose.yml
  env                   Show stack environment variables

DEVELOPMENT:
  artisan <cmd>         Run a Laravel artisan command
  scan                  Scan music library (koel:scan)
  bash                  Open a bash shell in the container
  shell                 SSH into the Plex VM

LOGS:
  logs [n]              Koel container logs (default: last 100 lines)
  db-logs [n]           MariaDB container logs

DATABASE:
  db                    Open MariaDB CLI

EXAMPLES:
  koel status
  koel search "bohemian rhapsody"
  koel albums "Pink Floyd"
  koel recent
  koel stats
  koel playlists
  koel logs 200
  koel artisan migrate --force
  koel deploy
HELP
}

# ── Main ─────────────────────────────────────────────────────

main() {
    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        status)         cmd_status ;;
        logs)           cmd_logs "${1:-100}" ;;
        db-logs)        cmd_db_logs "${1:-50}" ;;
        artisan)        cmd_artisan "$@" ;;
        shell|ssh)      cmd_shell ;;
        bash)           cmd_bash ;;
        db|mysql)       cmd_db ;;
        deploy)         cmd_deploy ;;
        restart)        cmd_restart ;;
        scan)           cmd_scan ;;
        env)            cmd_env ;;
        compose)        cmd_compose ;;
        open)           cmd_open ;;
        search)         cmd_search "$@" ;;
        playlists)      cmd_playlists ;;
        recent)         cmd_recent ;;
        stats)          cmd_stats ;;
        albums)         cmd_albums "$@" ;;
        artists)        cmd_artists ;;
        help|--help|-h) cmd_help ;;
        *)
            err "Unknown command: $cmd"
            cmd_help >&2
            exit 1
            ;;
    esac
}

main "$@"
