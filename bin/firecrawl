#!/usr/bin/env bash
# firecrawl - CLI for self-hosted Firecrawl (Services VM)
# Upgraded: formatted output, save-to-file, health check, extract

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
source "$SCRIPT_DIR/../lib/common.sh"

# ── Config (loaded from ~/.config/homelab-cli/config) ────────
FIRECRAWL_URL="${FIRECRAWL_URL:-http://localhost:3002}"
JOB_CACHE="${HOME}/.cache/homelab-cli/firecrawl-jobs"

# ── Helpers ──────────────────────────────────────────────────

fc_post() {
    local path="$1"; shift
    curl -s -X POST "${FIRECRAWL_URL}${path}" \
        -H "Content-Type: application/json" "$@"
}

fc_get() { curl -s "${FIRECRAWL_URL}${1}"; }

record_job() {
    local job_id="$1" url="$2"
    mkdir -p "$(dirname "$JOB_CACHE")"
    echo "${job_id}|${url}|$(date -u +%Y-%m-%dT%H:%M:%SZ)" >> "$JOB_CACHE"
}

# ── Commands ─────────────────────────────────────────────────

cmd_scrape() {
    local url="" format="markdown" output="" wait_ms="" headers_str=""

    # First arg is URL (required)
    [[ $# -lt 1 ]] && die "Usage: firecrawl scrape <url> [format] [outfile] [--wait N] [--headers 'K:V,...']"
    url="$1"; shift

    # Parse remaining: positional (format, outfile) then flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --wait)    wait_ms="${2:-}"; shift 2 ;;
            --headers) headers_str="${2:-}"; shift 2 ;;
            *)
                if [[ "$format" == "markdown" && ! "$1" =~ ^-- ]]; then
                    format="$1"; shift
                elif [[ -z "$output" && ! "$1" =~ ^-- ]]; then
                    output="$1"; shift
                else
                    die "Unknown option: $1"
                fi
                ;;
        esac
    done

    local result
    result=$(URL="$url" FMT="$format" WAIT="$wait_ms" HDRS="$headers_str" python3 -c "
import os, json
payload = {'url': os.environ['URL'], 'formats': [os.environ['FMT']]}
wait = os.environ.get('WAIT', '')
if wait:
    payload['waitFor'] = int(wait)
hdrs = os.environ.get('HDRS', '')
if hdrs:
    h = {}
    for pair in hdrs.split(','):
        if ':' in pair:
            k, v = pair.split(':', 1)
            h[k.strip()] = v.strip()
    if h:
        payload['headers'] = h
print(json.dumps(payload))
")
    local response
    response=$(fc_post "/v1/scrape" -d "$result")

    if [[ -n "$output" ]]; then
        FMT="$format" python3 -c "
import sys, json, os
data = json.loads('''$(echo "$response" | sed "s/'''/\"/g")''')
if not data.get('success'):
    print('Error:', data.get('error', 'Unknown'), file=sys.stderr)
    sys.exit(1)
content = data.get('data', {})
fmt = os.environ['FMT']
text = content.get(fmt, content.get('markdown', ''))
print(text)
" > "$output"
        ok "Saved to $output ($(wc -c < "$output") bytes)"
    else
        FMT="$format" python3 <<'PYEOF' - "$response"
import sys, json, os
data = json.loads(sys.argv[1]) if len(sys.argv) > 1 else json.load(sys.stdin)
if not data.get('success'):
    print('Error:', data.get('error', 'Unknown'), file=sys.stderr)
    sys.exit(1)
content = data.get('data', {})
fmt = os.environ['FMT']
text = content.get(fmt, content.get('markdown', ''))
print(text)
PYEOF
    fi
}

cmd_crawl() {
    local url="" limit="10" depth="" include="" exclude=""

    [[ $# -lt 1 ]] && die "Usage: firecrawl crawl <url> [limit] [--depth N] [--include PATTERN] [--exclude PATTERN]"
    url="$1"; shift

    # Parse remaining: positional (limit) then flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --depth)   depth="${2:-}"; shift 2 ;;
            --include) include="${2:-}"; shift 2 ;;
            --exclude) exclude="${2:-}"; shift 2 ;;
            *)
                if [[ "$limit" == "10" && ! "$1" =~ ^-- ]]; then
                    limit="$1"; shift
                else
                    die "Unknown option: $1"
                fi
                ;;
        esac
    done

    local payload
    payload=$(URL="$url" LIMIT="$limit" DEPTH="$depth" INCLUDE="$include" EXCLUDE="$exclude" python3 -c "
import os, json
payload = {
    'url': os.environ['URL'],
    'limit': int(os.environ['LIMIT']),
    'scrapeOptions': {'formats': ['markdown']}
}
depth = os.environ.get('DEPTH', '')
if depth:
    payload['maxDepth'] = int(depth)
inc = os.environ.get('INCLUDE', '')
if inc:
    payload['includePaths'] = [inc]
exc = os.environ.get('EXCLUDE', '')
if exc:
    payload['excludePaths'] = [exc]
print(json.dumps(payload))
")
    local response
    response=$(fc_post "/v1/crawl" -d "$payload")

    python3 <<'PYEOF' - "$response"
import sys, json
data = json.loads(sys.argv[1])
jid = data.get('id', '')
if not jid:
    print('Error:', json.dumps(data, indent=2), file=sys.stderr)
    sys.exit(1)
print(f'Crawl started: {jid}')
print(f'Check status:  firecrawl status {jid}')
PYEOF

    # Record job for tracking
    local jid
    jid=$(python3 -c "import sys,json; print(json.loads(sys.argv[1]).get('id',''))" "$response" 2>/dev/null || true)
    [[ -n "$jid" ]] && record_job "$jid" "$url"
}

cmd_status() {
    local job_id="$1"
    fc_get "/v1/crawl/$job_id" | python3 -c "
import sys, json
data = json.load(sys.stdin)
status = data.get('status', '?')
total = data.get('total', 0)
completed = data.get('completed', 0)
print(f'Status:   {status}')
print(f'Progress: {completed}/{total}')
if status == 'completed':
    pages = data.get('data', [])
    print(f'Pages:    {len(pages)}')
    for p in pages[:30]:
        meta = p.get('metadata', {})
        title = meta.get('title', '?')[:60]
        url = meta.get('sourceURL', '?')[:80]
        print(f'  {title}')
        print(f'    {url}')
"
}

cmd_map() {
    local url="$1"
    local payload
    payload=$(URL="$url" python3 -c "import os,json; print(json.dumps({'url': os.environ['URL']}))")
    fc_post "/v1/map" -d "$payload" | python3 -c "
import sys, json
data = json.load(sys.stdin)
if not data.get('success'):
    print('Error:', data.get('error', 'Unknown'), file=sys.stderr)
    sys.exit(1)
links = data.get('links', [])
print(f'Found {len(links)} URLs:')
for l in links:
    print(f'  {l}')
"
}

cmd_search() {
    local query="$1" limit="${2:-5}"
    local payload
    payload=$(Q="$query" L="$limit" python3 -c "
import os, json
print(json.dumps({'query': os.environ['Q'], 'limit': int(os.environ['L']),
    'scrapeOptions': {'formats': ['markdown']}}))
")
    fc_post "/v1/search" -d "$payload" | python3 -c "
import sys, json
data = json.load(sys.stdin)
if not data.get('success'):
    print('Error:', data.get('error', 'Unknown'), file=sys.stderr)
    sys.exit(1)
results = data.get('data', [])
print(f'{len(results)} results:')
for r in results:
    meta = r.get('metadata', {})
    title = meta.get('title', '?')[:70]
    url = meta.get('sourceURL', '?')
    print(f'  {title}')
    print(f'    {url}')
    desc = meta.get('description', '')[:120]
    if desc:
        print(f'    {desc}')
    print()
"
}

cmd_extract() {
    local url="$1" prompt="$2"
    local payload
    payload=$(URL="$url" PROMPT="$prompt" python3 -c "
import os, json
print(json.dumps({'urls': [os.environ['URL']], 'prompt': os.environ['PROMPT']}))
")
    fc_post "/v1/extract" -d "$payload" | python3 -m json.tool
}

cmd_batch() {
    [[ $# -lt 1 ]] && die "Usage: firecrawl batch <url1> [url2 ...]"

    local urls_str=""
    for u in "$@"; do
        urls_str="${urls_str}${u}"$'\n'
    done

    local payload
    payload=$(URLS="$urls_str" python3 -c "
import os, json
urls = [u.strip() for u in os.environ['URLS'].strip().split('\n') if u.strip()]
print(json.dumps({'urls': urls, 'formats': ['markdown']}))
")

    info "Batch scraping ${#} URL(s)..."
    local response
    response=$(fc_post "/v1/batch/scrape" -d "$payload")

    python3 <<'PYEOF' - "$response"
import sys, json
data = json.loads(sys.argv[1]) if len(sys.argv) > 1 else json.load(sys.stdin)
if not data.get('success', True):
    print('Error:', data.get('error', 'Unknown'), file=sys.stderr)
    sys.exit(1)

# batch/scrape may return {id, url} for async or {success, data} for sync
if 'id' in data:
    print(f"Batch job started: {data['id']}")
    print(f"Check status:  firecrawl status {data['id']}")
else:
    results = data.get('data', [])
    print(f'{len(results)} page(s) scraped:\n')
    for r in results:
        meta = r.get('metadata', {})
        title = meta.get('title', '(no title)')[:70]
        url = meta.get('sourceURL', meta.get('url', '?'))[:80]
        md = r.get('markdown', '')
        words = len(md.split()) if md else 0
        print(f'  {title}')
        print(f'    {url}')
        print(f'    {words} words')
        print()
PYEOF

    # Record batch job for tracking
    local jid
    jid=$(python3 -c "import sys,json; print(json.loads(sys.argv[1]).get('id',''))" "$response" 2>/dev/null || true)
    [[ -n "$jid" ]] && record_job "$jid" "batch:${1}"
}

cmd_cancel() {
    local job_id="${1:-}"
    [[ -z "$job_id" ]] && die "Usage: firecrawl cancel <job_id>"

    confirm_action "Cancel crawl job '$job_id'?"

    local response
    response=$(curl -s -X DELETE "${FIRECRAWL_URL}/v1/crawl/${job_id}")

    python3 <<PYEOF - "$response"
import sys, json
try:
    data = json.loads(sys.argv[1]) if len(sys.argv) > 1 else {}
    if data.get('success') == False:
        print(f"Error: {data.get('error', 'Unknown')}", file=sys.stderr)
        sys.exit(1)
except (json.JSONDecodeError, IndexError):
    pass
PYEOF

    ok "  Cancelled job: $job_id"
}

cmd_jobs() {
    if [[ ! -f "$JOB_CACHE" ]]; then
        info "No tracked jobs yet. Jobs are recorded when you run crawl or batch."
        return
    fi

    local entries
    entries=$(tail -20 "$JOB_CACHE")

    ENTRIES="$entries" FC_URL="$FIRECRAWL_URL" python3 <<'PYEOF'
import os, json, urllib.request, sys

entries = os.environ['ENTRIES'].strip().split('\n')
fc_url = os.environ['FC_URL']

print(f"{'ID':10} {'URL':52} {'STATUS':12} {'PAGES':8} {'CREATED'}")
print('-' * 100)

for line in reversed(entries):
    parts = line.strip().split('|')
    if len(parts) < 3:
        continue
    jid, url, created = parts[0], parts[1], parts[2]
    short_id = jid[:8]
    short_url = url[:50] + ('...' if len(url) > 50 else '')
    created_short = created[:16].replace('T', ' ')

    # Query status
    try:
        req = urllib.request.Request(f"{fc_url}/v1/crawl/{jid}")
        with urllib.request.urlopen(req, timeout=3) as resp:
            data = json.loads(resp.read())
        status = data.get('status', '?')
        completed = data.get('completed', 0)
        total = data.get('total', 0)
        pages = f"{completed}/{total}"
    except Exception:
        status = '?'
        pages = '-'

    print(f'{short_id:10} {short_url:52} {status:12} {pages:8} {created_short}')
PYEOF
}

cmd_health() {
    local code
    code=$(curl -s -o /dev/null -w "%{http_code}" "${FIRECRAWL_URL}/v1/scrape" \
        -X POST -H "Content-Type: application/json" \
        -d '{"url":"https://example.com","formats":["markdown"]}' 2>/dev/null)
    if [[ "$code" == "200" ]]; then
        ok "Firecrawl OK at $FIRECRAWL_URL (HTTP $code)"
    else
        warn "Firecrawl returned HTTP $code at $FIRECRAWL_URL"
    fi
}

cmd_help() {
    show_version "firecrawl"
    cat <<HELP
CLI for self-hosted Firecrawl (Services VM)

USAGE:
  firecrawl <command> [args...]

SCRAPING:
  scrape <url> [fmt] [outfile]     Scrape a page (markdown|html|links)
    --wait <ms>                      Wait time for JS-heavy pages
    --headers 'K:V,K2:V2'           Custom request headers
  batch <url1> [url2 ...]          Batch scrape multiple URLs

CRAWLING:
  crawl <url> [limit]              Crawl a site (default: 10 pages)
    --depth <n>                      Max crawl depth (default: 2)
    --include <pattern>              Include URL paths matching pattern
    --exclude <pattern>              Exclude URL paths matching pattern
  status <job_id>                  Check crawl job status and results

JOB MANAGEMENT:
  cancel <job_id>                  Cancel a running crawl job
  jobs                             List recent tracked jobs

DISCOVERY:
  map <url>                        Discover all URLs on a site
  search <query> [limit]           Search the web (default: 5 results)
  extract <url> <prompt>           Extract structured data with a prompt

OTHER:
  health                           Check Firecrawl status
  help                             Show this help

EXAMPLES:
  firecrawl scrape https://example.com
  firecrawl scrape https://docs.laravel.com --wait 3000 --headers 'Accept-Language:en'
  firecrawl scrape https://docs.laravel.com/auth markdown auth.md
  firecrawl batch https://example.com https://example.org https://example.net
  firecrawl crawl https://docs.laravel.com 20 --depth 3 --include '/docs/'
  firecrawl crawl https://example.com --exclude '/blog/'
  firecrawl status abc-123-def
  firecrawl cancel abc-123-def
  firecrawl jobs
  firecrawl map https://spotify.com
  firecrawl search "spotify wrapped design patterns"
  firecrawl extract https://example.com "extract all product names and prices"

ENVIRONMENT:
  FIRECRAWL_URL    Override base URL (default: from config or http://localhost:3002)
HELP
}

# ── Main ─────────────────────────────────────────────────────

main() {
    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        scrape)
            [[ $# -lt 1 ]] && { echo "Usage: firecrawl scrape <url> [format] [outfile] [--wait N] [--headers 'K:V,...']"; exit 1; }
            cmd_scrape "$@"
            ;;
        batch)
            [[ $# -lt 1 ]] && { echo "Usage: firecrawl batch <url1> [url2 ...]"; exit 1; }
            cmd_batch "$@"
            ;;
        crawl)
            [[ $# -lt 1 ]] && { echo "Usage: firecrawl crawl <url> [limit] [--depth N] [--include PATTERN] [--exclude PATTERN]"; exit 1; }
            cmd_crawl "$@"
            ;;
        status)
            [[ $# -lt 1 ]] && { echo "Usage: firecrawl status <job_id>"; exit 1; }
            cmd_status "$1"
            ;;
        map)
            [[ $# -lt 1 ]] && { echo "Usage: firecrawl map <url>"; exit 1; }
            cmd_map "$1"
            ;;
        search)
            [[ $# -lt 1 ]] && { echo "Usage: firecrawl search <query> [limit]"; exit 1; }
            cmd_search "$1" "${2:-5}"
            ;;
        extract)
            [[ $# -lt 2 ]] && { echo "Usage: firecrawl extract <url> <prompt>"; exit 1; }
            cmd_extract "$1" "$2"
            ;;
        cancel)
            [[ $# -lt 1 ]] && { echo "Usage: firecrawl cancel <job_id>"; exit 1; }
            cmd_cancel "$1"
            ;;
        jobs)
            cmd_jobs
            ;;
        health)   cmd_health ;;
        help|--help|-h) cmd_help ;;
        *)
            err "Unknown command: $cmd"
            cmd_help >&2
            exit 1
            ;;
    esac
}

main "$@"
