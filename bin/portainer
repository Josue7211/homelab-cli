    pt_api_post "$instance" "/endpoints/$eid/docker/containers/$container_id/stop" > /dev/null
    ok "Container '$container_name' stopped."
}

cmd_start_ct() {
    local instance="${1:-$DEFAULT_INSTANCE}" container_name="$2"
    local eid="${ENDPOINT_IDS[$instance]}"
    local container_id
    container_id=$(resolve_container_id "$instance" "$container_name")
    info "Starting $container_name on $instance..."
    pt_api_post "$instance" "/endpoints/$eid/docker/containers/$container_id/start" > /dev/null
    ok "Container '$container_name' started."
}

cmd_inspect() {
    local instance="${1:-$DEFAULT_INSTANCE}" container_name="$2"
    local eid="${ENDPOINT_IDS[$instance]}"
    local container_id
    container_id=$(resolve_container_id "$instance" "$container_name")
    pt_api_get "$instance" "/endpoints/$eid/docker/containers/$container_id/json" | python3 -c "
import sys, json, re
data = json.load(sys.stdin)
state = data.get('State', {})
config = data.get('Config', {})
network = data.get('NetworkSettings', {})
mounts = data.get('Mounts', [])

# Header
name = data.get('Name', '?').lstrip('/')
print(f'  Container: {name}')
print(f'  Image:     {config.get(\"Image\", \"?\")}')
print(f'  ID:        {data.get(\"Id\", \"?\")[:12]}')
print(f'  Status:    {state.get(\"Status\", \"?\")}')
print(f'  Started:   {state.get(\"StartedAt\", \"?\")}')
print()

# Ports
ports = network.get('Ports', {})
if ports:
    print('  Ports:')
    for container_port, bindings in sorted(ports.items()):
        if bindings:
            for b in bindings:
                print(f'    {b.get(\"HostIp\",\"0.0.0.0\")}:{b.get(\"HostPort\",\"?\")} -> {container_port}')
        else:
            print(f'    {container_port} (not published)')
    print()

# Mounts
if mounts:
    print('  Mounts:')
    for m in mounts:
        src = m.get('Source', '?')
        dst = m.get('Destination', '?')
        mode = 'ro' if not m.get('RW', True) else 'rw'
        print(f'    {src} -> {dst} ({mode})')
    print()

# Env vars (masked)
env = config.get('Env', [])
if env:
    print('  Environment:')
    sensitive = re.compile(r'(PASSWORD|SECRET|TOKEN|KEY|APIKEY|API_KEY)', re.IGNORECASE)
    for e in sorted(env):
        k, _, v = e.partition('=')
        if sensitive.search(k):
            print(f'    {k}=********')
        else:
            print(f'    {k}={v}')
    print()

# Networks
nets = network.get('Networks', {})
if nets:
    print('  Networks:')
    for net_name, net_info in sorted(nets.items()):
        ip = net_info.get('IPAddress', '?')
        print(f'    {net_name}: {ip}')
"
}

cmd_container_exec() {
    local instance="${1:-$DEFAULT_INSTANCE}" container_name="$2"
    shift 2 || { err "Usage: portainer exec <instance> <name> <cmd...>"; exit 1; }
    local eid="${ENDPOINT_IDS[$instance]}"
    local container_id
    container_id=$(resolve_container_id "$instance" "$container_name")

    # Create exec instance
    local exec_payload
    exec_payload=$(CMD="$*" python3 -c "
import json, os, shlex
cmd = shlex.split(os.environ['CMD'])
print(json.dumps({
    'AttachStdin': False,
    'AttachStdout': True,
    'AttachStderr': True,
    'Tty': False,
    'Cmd': cmd
}))
")

    local exec_id
    exec_id=$(pt_api_post "$instance" "/endpoints/$eid/docker/containers/$container_id/exec" -d "$exec_payload" | \
        python3 -c "import sys,json; print(json.load(sys.stdin).get('Id',''))")

    if [[ -z "$exec_id" ]]; then
        die "Failed to create exec instance in '$container_name'"
    fi

    # Start exec instance and stream output
    pt_api_post "$instance" "/endpoints/$eid/docker/exec/$exec_id/start" \
        -d '{"Detach": false, "Tty": false}'
}

cmd_top() {
    local instance="${1:-$DEFAULT_INSTANCE}" container_name="$2"
    local eid="${ENDPOINT_IDS[$instance]}"
    local container_id
    container_id=$(resolve_container_id "$instance" "$container_name")
    pt_api_get "$instance" "/endpoints/$eid/docker/containers/$container_id/top" | python3 -c "
import sys, json
data = json.load(sys.stdin)
titles = data.get('Titles', [])
procs = data.get('Processes', [])
if not procs:
    print('  No running processes.')
    sys.exit()
# Print header
print('  ' + '  '.join(f'{t:<12}' for t in titles))
print('  ' + '  '.join('-' * 12 for _ in titles))
for proc in procs:
    print('  ' + '  '.join(f'{p:<12}' for p in proc))
"
}

cmd_volumes() {
    local instance="${1:-$DEFAULT_INSTANCE}"
    local eid="${ENDPOINT_IDS[$instance]}"
    pt_api_get "$instance" "/endpoints/$eid/docker/volumes" | python3 -c "
import sys, json
data = json.load(sys.stdin)
volumes = data.get('Volumes', [])
if not volumes:
    print('  No volumes found.')
    sys.exit()
print(f'  {\"Name\":<40} {\"Driver\":<10} {\"Mountpoint\"}')
print(f'  {\"─\"*39} {\"─\"*9} {\"─\"*40}')
for v in sorted(volumes, key=lambda x: x.get('Name', '')):
    name = v.get('Name', '?')
    if len(name) > 38:
        name = name[:35] + '...'
    driver = v.get('Driver', '?')
    mount = v.get('Mountpoint', '?')
    print(f'  {name:<40} {driver:<10} {mount}')
print(f'\n  Total: {len(volumes)} volumes')
"
}

cmd_networks() {
    local instance="${1:-$DEFAULT_INSTANCE}"
    local eid="${ENDPOINT_IDS[$instance]}"
    pt_api_get "$instance" "/endpoints/$eid/docker/networks" | python3 -c "
import sys, json
networks = json.load(sys.stdin)
if not networks:
    print('  No networks found.')
    sys.exit()
print(f'  {\"Name\":<30} {\"Driver\":<12} {\"Scope\":<10} {\"Subnet\"}')
print(f'  {\"─\"*29} {\"─\"*11} {\"─\"*9} {\"─\"*18}')
for n in sorted(networks, key=lambda x: x.get('Name', '')):
    name = n.get('Name', '?')
    driver = n.get('Driver', '?')
    scope = n.get('Scope', '?')
    ipam = n.get('IPAM', {}).get('Config', [])
    subnet = ipam[0].get('Subnet', '-') if ipam else '-'
    print(f'  {name:<30} {driver:<12} {scope:<10} {subnet}')
"
}

cmd_images() {
    local instance="${1:-$DEFAULT_INSTANCE}"
    local eid="${ENDPOINT_IDS[$instance]}"
    pt_api_get "$instance" "/endpoints/$eid/docker/images/json" | python3 -c "
import sys, json
images = json.load(sys.stdin)
if not images:
    print('  No images found.')
    sys.exit()

def human_size(b):
    for u in ['B','KB','MB','GB','TB']:
        if b < 1024: return f'{b:.1f} {u}'
        b /= 1024
    return f'{b:.1f} PB'

print(f'  {\"Repository:Tag\":<55} {\"Size\":<12} {\"ID\"}')
print(f'  {\"─\"*54} {\"─\"*11} {\"─\"*12}')
total_size = 0
for img in sorted(images, key=lambda x: (x.get('RepoTags') or ['<none>'])[0]):
    tags = img.get('RepoTags') or ['<none>:<none>']
    size = img.get('Size', 0)
    total_size += size
    img_id = img.get('Id', '?').replace('sha256:', '')[:12]
    for tag in tags:
        if len(tag) > 53:
            tag = tag[:50] + '...'
        print(f'  {tag:<55} {human_size(size):<12} {img_id}')
print(f'\n  Total: {len(images)} images, {human_size(total_size)}')
"
}

cmd_endpoints() {
    for inst in services plex; do
        header "$inst (${URLS[$inst]})"
        pt_api_get "$inst" "/endpoints" | python3 -c "
import sys, json
endpoints = json.load(sys.stdin)
if not endpoints:
    print('  No endpoints found.')
    sys.exit()
print(f'  {\"ID\":<5} {\"Name\":<25} {\"Type\":<8} {\"URL\":<35} {\"Status\"}')
print(f'  {\"─\"*4} {\"─\"*24} {\"─\"*7} {\"─\"*34} {\"─\"*8}')
type_map = {1: 'Docker', 2: 'Agent', 3: 'Azure', 4: 'Edge', 5: 'K8s'}
for ep in sorted(endpoints, key=lambda x: x.get('Id', 0)):
    eid = ep.get('Id', '?')
    name = ep.get('Name', '?')
    etype = type_map.get(ep.get('Type', 0), '?')
    url = ep.get('URL', '?')
    status = 'Up' if ep.get('Status', 0) == 1 else 'Down'
    print(f'  {eid:<5} {name:<25} {etype:<8} {url:<35} {status}')
" 2>/dev/null || warn "  Could not reach $inst"
    done
}

cmd_status() {
    for inst in services plex; do
        local ver
        ver=$(curl ${CURL_FLAGS[$inst]} "${URLS[$inst]}/api/status" 2>/dev/null | python3 -c "import sys,json; print(json.load(sys.stdin).get('Version','?'))" 2>/dev/null || echo "unreachable")
        printf "  %-10s %s  (v%s)\n" "$inst" "${URLS[$inst]}" "$ver"
    done
}

# ── Helpers ──────────────────────────────────────────────────────

resolve_stack_id() {
    local instance="$1" stack_name="$2"
    local result
    result=$(pt_api_get "$instance" "/stacks" | SEARCH="$stack_name" python3 -c "
import sys, json, os
name = os.environ['SEARCH']
for s in json.load(sys.stdin):
    if s['Name'] == name:
        print(s['Id'])
        sys.exit()
# Try numeric ID
try:
    print(int(name))
except:
    print('NOT_FOUND')
" 2>/dev/null)

    if [[ "$result" == "NOT_FOUND" || -z "$result" ]]; then
        err "Stack '$stack_name' not found on $instance"
        echo "Available stacks:" >&2
        cmd_stacks "$instance" >&2
        exit 1
    fi
    echo "$result"
}

resolve_container_id() {
    local instance="$1" container_name="$2"
    local eid="${ENDPOINT_IDS[$instance]}"
    local container_id
    container_id=$(pt_api_get "$instance" "/endpoints/$eid/docker/containers/json?all=true" | \
        SEARCH="$container_name" python3 -c "
import sys, json, os
search = os.environ['SEARCH']
for c in json.load(sys.stdin):
    if any(n.lstrip('/') == search for n in c.get('Names',[])):
        print(c['Id'][:12])
        sys.exit()
print('NOT_FOUND')
" 2>/dev/null)

    if [[ "$container_id" == "NOT_FOUND" || -z "$container_id" ]]; then
        die "Container '$container_name' not found on $instance"
    fi
    echo "$container_id"
}

cmd_help() {
    show_version "portainer"
    cat <<'HELP'

Manage Portainer instances (Services + Plex VMs)

USAGE:
  portainer <command> [instance] [args...]

  Instance: "services" (default) or "plex"

COMMANDS:
  status                          Show all Portainer instances and versions
  stacks [instance]               List all stacks
  stack <instance> <name>         Show stack details (JSON)
  compose <instance> <name>       Show stack docker-compose.yml
  env <instance> <name>           Show stack environment variables
  containers [instance]           List all containers
  logs <instance> <name> [tail]   Show container logs (default: last 100 lines)
  restart <instance> <name>       Restart a container
  redeploy <instance> <name>      Redeploy stack (pull images + prune)
  create <inst> <name> -f <file> [--env K=V...]  Create stack from compose file
  create <inst> <name> --inline [--env K=V...]   Create stack from stdin
  delete <inst> <name>            Delete stack (with confirmation)
  start-stack <inst> <name>       Start a stopped stack
  stop-stack <inst> <name>        Stop a running stack
  update-env <inst> <name> K=V...   Update stack environment variables
  edit <inst> <name> -f <file>      Update stack compose and redeploy
  stop-ct <inst> <name>             Stop a container
  start-ct <inst> <name>            Start a stopped container
  inspect <inst> <name>             Inspect container (ports, mounts, env, state)
  exec <inst> <name> <cmd...>       Run command in container
  top <inst> <name>                 Show running processes in container
  volumes [instance]              List Docker volumes
  networks [instance]             List Docker networks with subnets
  images [instance]               List Docker images with sizes
  endpoints                       List all Portainer endpoints
  help                            Show this help

EXAMPLES:
  portainer status
  portainer stacks plex
  portainer containers services
  portainer logs plex koel 50
  portainer compose plex music
  portainer redeploy plex music
  portainer restart services firecrawl

TOKENS:
  Retrieved from Vaultwarden (bw CLI) at runtime. Unlock with: bw unlock
HELP
}

# ── Main ─────────────────────────────────────────────────────────

main() {
    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        status)     cmd_status ;;
        stacks|ls)  cmd_stacks "${1:-$DEFAULT_INSTANCE}" ;;
        stack)      cmd_stack "$1" "$2" ;;
        compose)    cmd_compose "$1" "$2" ;;
        env)        cmd_env "$1" "$2" ;;
        containers|ps) cmd_containers "${1:-$DEFAULT_INSTANCE}" ;;
        logs)       cmd_logs "$1" "$2" "${3:-100}" ;;
        restart)    cmd_restart "$1" "$2" ;;
        redeploy)   cmd_redeploy "$1" "$2" ;;
        create)     cmd_create "$@" ;;
        delete|rm)  cmd_delete_stack "$1" "$2" ;;
        start-stack) cmd_start_stack "$1" "$2" ;;
        stop-stack) cmd_stop_stack "$1" "$2" ;;
        update-env) cmd_update_env "$@" ;;
        edit)       cmd_edit "$@" ;;
        stop-ct)    cmd_stop_ct "$1" "$2" ;;
        start-ct)   cmd_start_ct "$1" "$2" ;;
        inspect)    cmd_inspect "$1" "$2" ;;
        exec)       cmd_container_exec "$@" ;;
        top)        cmd_top "$1" "$2" ;;
        volumes)    cmd_volumes "${1:-$DEFAULT_INSTANCE}" ;;
        networks)   cmd_networks "${1:-$DEFAULT_INSTANCE}" ;;
        images)     cmd_images "${1:-$DEFAULT_INSTANCE}" ;;
        endpoints)  cmd_endpoints ;;
        help|--help|-h) cmd_help ;;
        *)
            err "Unknown command: $cmd"
            cmd_help >&2
            exit 1
            ;;
    esac
}

main "$@"
