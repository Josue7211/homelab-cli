#!/usr/bin/env bash
# portainer - CLI for managing Portainer instances (Services + Plex VMs)
# Tokens retrieved from Vaultwarden via `bw` CLI at runtime.

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
source "$SCRIPT_DIR/../lib/common.sh"

# ── Instance config (from config file, with safe defaults) ──────
declare -A URLS VAULT_ENTRIES ENDPOINT_IDS CURL_FLAGS
URLS[services]="${PORTAINER_SERVICES:-https://localhost:9443}"
URLS[plex]="${PORTAINER_PLEX:-http://localhost:9000}"
VAULT_ENTRIES[services]="${PORTAINER_SERVICES_BW_ENTRY:-Portainer API - Services VM}"
VAULT_ENTRIES[plex]="${PORTAINER_PLEX_BW_ENTRY:-Portainer API - Plex VM}"
ENDPOINT_IDS[services]="${PORTAINER_SERVICES_ENDPOINT_ID:-3}"
ENDPOINT_IDS[plex]="${PORTAINER_PLEX_ENDPOINT_ID:-3}"

# Determine curl flags from URL scheme
for _inst in services plex; do
    if [[ "${URLS[$_inst]}" == https://* ]]; then
        CURL_FLAGS[$_inst]="-sk"   # HTTPS self-signed
    else
        CURL_FLAGS[$_inst]="-s"    # plain HTTP
    fi
done
unset _inst

DEFAULT_INSTANCE="${PORTAINER_DEFAULT_INSTANCE:-services}"
TOKEN_SOURCE="${PORTAINER_TOKEN_SOURCE:-bw}"

# ── Token cache (per-session) ────────────────────────────────────
CACHE_DIR="${XDG_RUNTIME_DIR:-/tmp}/portainer-cli-$$"
mkdir -p "$CACHE_DIR"
trap 'rm -rf "$CACHE_DIR"' EXIT

get_token() {
    local instance="$1"
    local cache_file="$CACHE_DIR/token-$instance"

    if [[ -f "$cache_file" ]]; then
        cat "$cache_file"
        return
    fi

    local token
    token=$(get_secret "$TOKEN_SOURCE" "${VAULT_ENTRIES[$instance]}") || {
        die "Failed to get token for $instance. Is vault unlocked? (bw unlock)"
    }
    echo "$token" > "$cache_file"
    echo "$token"
}

# ── API helpers ──────────────────────────────────────────────────
pt_api() {
    local instance="$1" method="$2" path="$3"
    shift 3
    local token
    token=$(get_token "$instance")
    local url="${URLS[$instance]}/api${path}"
    local flags="${CURL_FLAGS[$instance]}"
    # shellcheck disable=SC2086
    curl $flags -X "$method" "$url" \
        -H "X-API-Key: $token" \
        -H "Content-Type: application/json" \
        "$@"
}

pt_api_get()    { pt_api "$1" GET "$2"; }
pt_api_post()   { pt_api "$1" POST "$2" "${@:3}"; }
pt_api_put()    { pt_api "$1" PUT "$2" "${@:3}"; }
pt_api_delete() { pt_api "$1" DELETE "$2"; }

fmt_json() { python3 -m json.tool 2>/dev/null || cat; }

# ── Commands ─────────────────────────────────────────────────────

cmd_stacks() {
    local instance="${1:-$DEFAULT_INSTANCE}"
    pt_api_get "$instance" "/stacks" | python3 -c "
import sys, json
stacks = json.load(sys.stdin)
if not stacks:
    print('  No stacks found.')
    sys.exit()
print(f'  {\"ID\":<5} {\"Name\":<25} {\"Status\":<12} {\"Created\"}')
print(f'  {\"─\"*4} {\"─\"*24} {\"─\"*11} {\"─\"*20}')
for s in sorted(stacks, key=lambda x: x['Id']):
    status = 'Active' if s.get('Status') == 1 else 'Inactive'
    name = s.get('Name', '?')
    sid = s['Id']
    print(f'  {sid:<5} {name:<25} {status:<12}')
"
}

cmd_stack() {
    local instance="${1:-$DEFAULT_INSTANCE}" stack_name="$2"
    local stack_id
    stack_id=$(resolve_stack_id "$instance" "$stack_name")
    pt_api_get "$instance" "/stacks/$stack_id" | fmt_json
}

cmd_containers() {
    local instance="${1:-$DEFAULT_INSTANCE}"
    local eid="${ENDPOINT_IDS[$instance]}"
    pt_api_get "$instance" "/endpoints/$eid/docker/containers/json?all=true" | python3 -c "
import sys, json
data = json.load(sys.stdin)
containers = data if isinstance(data, list) else []
if not containers:
    print('  No containers found.')
    sys.exit()
print(f'  {\"Name\":<30} {\"State\":<12} {\"Status\":<25} {\"Image\"}')
print(f'  {\"─\"*29} {\"─\"*11} {\"─\"*24} {\"─\"*40}')
for c in sorted(containers, key=lambda x: x.get('Names',[''])[0]):
    name = c.get('Names',['?'])[0].lstrip('/')
    state = c.get('State', '?')
    status = c.get('Status', '?')
    image = c.get('Image', '?')[:50]
    print(f'  {name:<30} {state:<12} {status:<25} {image}')
"
}

cmd_logs() {
    local instance="${1:-$DEFAULT_INSTANCE}" container_name="$2" tail="${3:-100}"
    local eid="${ENDPOINT_IDS[$instance]}"
    local container_id
    container_id=$(resolve_container_id "$instance" "$container_name")
    pt_api_get "$instance" "/endpoints/$eid/docker/containers/$container_id/logs?stdout=true&stderr=true&tail=$tail" 2>/dev/null | \
        sed 's/^.\{8\}//g'
}

cmd_restart() {
    local instance="${1:-$DEFAULT_INSTANCE}" container_name="$2"
    local eid="${ENDPOINT_IDS[$instance]}"
    local container_id
    container_id=$(resolve_container_id "$instance" "$container_name")
    info "Restarting $container_name on $instance..."
    pt_api_post "$instance" "/endpoints/$eid/docker/containers/$container_id/restart" > /dev/null
    ok "Done."
}

cmd_redeploy() {
    local instance="${1:-$DEFAULT_INSTANCE}" stack_name="$2"
    local stack_id eid
    stack_id=$(resolve_stack_id "$instance" "$stack_name")
    eid="${ENDPOINT_IDS[$instance]}"

    # Get current stack config
    local stack_data
    stack_data=$(pt_api_get "$instance" "/stacks/$stack_id")

    local env_vars compose
    env_vars=$(echo "$stack_data" | python3 -c "import sys,json; print(json.dumps(json.load(sys.stdin).get('Env', [])))")
    compose=$(pt_api_get "$instance" "/stacks/$stack_id/file" | python3 -c "import sys,json; print(json.load(sys.stdin).get('StackFileContent', ''))")

    info "Redeploying stack '$stack_name' (ID: $stack_id) on $instance..."
    pt_api_put "$instance" "/stacks/$stack_id?endpointId=$eid" \
        -d "$(python3 -c "
import json, sys
print(json.dumps({
    'stackFileContent': '''$( echo "$compose" | sed "s/'/'\\\\''/g" )''',
    'env': $env_vars,
    'prune': True,
    'pullImage': True
}))
")" > /dev/null
    ok "Done. Stack redeployed with image pull + prune."
}

cmd_compose() {
    local instance="${1:-$DEFAULT_INSTANCE}" stack_name="$2"
    local stack_id
    stack_id=$(resolve_stack_id "$instance" "$stack_name")
    pt_api_get "$instance" "/stacks/$stack_id/file" | python3 -c "
import sys, json
print(json.load(sys.stdin).get('StackFileContent', 'No compose file found'))
"
}

cmd_env() {
    local instance="${1:-$DEFAULT_INSTANCE}" stack_name="$2"
    local stack_id
    stack_id=$(resolve_stack_id "$instance" "$stack_name")
    pt_api_get "$instance" "/stacks/$stack_id" | python3 -c "
import sys, json
stack = json.load(sys.stdin)
env = stack.get('Env', [])
if not env:
    print('  No environment variables.')
    sys.exit()
for e in sorted(env, key=lambda x: x['name']):
    print(f'  {e[\"name\"]}={e[\"value\"]}')
"
}

cmd_create() {
    local instance="${1:-$DEFAULT_INSTANCE}" stack_name="$2"
    shift 2 || { err "Usage: portainer create <instance> <name> [-f <file>] [--inline] [--env K=V...]"; exit 1; }

    local compose_content="" env_vars="[]" mode=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -f|--file) mode="file"; compose_content=$(cat "$2"); shift 2 ;;
            --inline)  mode="inline"; shift ;;
            --env)     shift
                       # Collect remaining K=V pairs as env
                       local env_json="["
                       local first=true
                       while [[ $# -gt 0 && "$1" != -* ]]; do
                           local key="${1%%=*}" val="${1#*=}"
                           [[ "$first" == "true" ]] && first=false || env_json+=","
                           env_json+="{\"name\":\"$key\",\"value\":\"$val\"}"
                           shift
                       done
                       env_json+="]"
                       env_vars="$env_json"
                       ;;
            *)  err "Unknown option: $1"; exit 1 ;;
        esac
    done

    # Read from stdin if --inline
    if [[ "$mode" == "inline" ]]; then
        compose_content=$(cat)
    fi

    if [[ -z "$compose_content" ]]; then
        die "No compose content provided. Use -f <file> or --inline (pipe via stdin)"
    fi

    local eid="${ENDPOINT_IDS[$instance]}"
    info "Creating stack '$stack_name' on $instance..."
    local payload
    payload=$(STACK="$stack_name" COMPOSE="$compose_content" ENV="$env_vars" python3 -c "
import json, os
print(json.dumps({
    'name': os.environ['STACK'],
    'stackFileContent': os.environ['COMPOSE'],
    'env': json.loads(os.environ['ENV'])
}))
")
    pt_api_post "$instance" "/stacks/create/standalone/string?endpointId=$eid" -d "$payload" > /dev/null
    ok "Stack '$stack_name' created on $instance."
}

cmd_delete_stack() {
    local instance="${1:-$DEFAULT_INSTANCE}" stack_name="$2"
    local stack_id eid
    stack_id=$(resolve_stack_id "$instance" "$stack_name")
    eid="${ENDPOINT_IDS[$instance]}"
    confirm_action "Delete stack '$stack_name' (ID: $stack_id) on $instance?"
    info "Deleting stack '$stack_name'..."
    pt_api_delete "$instance" "/stacks/$stack_id?endpointId=$eid"
    ok "Stack '$stack_name' deleted."
}

cmd_start_stack() {
    local instance="${1:-$DEFAULT_INSTANCE}" stack_name="$2"
    local stack_id eid
    stack_id=$(resolve_stack_id "$instance" "$stack_name")
    eid="${ENDPOINT_IDS[$instance]}"
    info "Starting stack '$stack_name' on $instance..."
    pt_api_post "$instance" "/stacks/$stack_id/start?endpointId=$eid" > /dev/null
    ok "Stack '$stack_name' started."
}

cmd_stop_stack() {
    local instance="${1:-$DEFAULT_INSTANCE}" stack_name="$2"
    local stack_id eid
    stack_id=$(resolve_stack_id "$instance" "$stack_name")
    eid="${ENDPOINT_IDS[$instance]}"
    info "Stopping stack '$stack_name' on $instance..."
    pt_api_post "$instance" "/stacks/$stack_id/stop?endpointId=$eid" > /dev/null
    ok "Stack '$stack_name' stopped."
}

cmd_update_env() {
    local instance="${1:-$DEFAULT_INSTANCE}" stack_name="$2"
    shift 2 || { err "Usage: portainer update-env <instance> <name> K=V..."; exit 1; }

    local stack_id eid
    stack_id=$(resolve_stack_id "$instance" "$stack_name")
    eid="${ENDPOINT_IDS[$instance]}"

    # Get current stack data
    local stack_data compose
    stack_data=$(pt_api_get "$instance" "/stacks/$stack_id")
    compose=$(pt_api_get "$instance" "/stacks/$stack_id/file" | python3 -c "import sys,json; print(json.load(sys.stdin).get('StackFileContent', ''))")

    # Build new env array: start with existing, override/add from args
    local env_json
    env_json=$(echo "$stack_data" | ARGS="$*" python3 -c "
import sys, json, os
stack = json.load(sys.stdin)
env = {e['name']: e['value'] for e in stack.get('Env', [])}
for pair in os.environ['ARGS'].split():
    if '=' in pair:
        k, v = pair.split('=', 1)
        env[k] = v
print(json.dumps([{'name': k, 'value': v} for k, v in sorted(env.items())]))
")

    info "Updating env vars for stack '$stack_name' on $instance..."
    local payload
    payload=$(COMPOSE="$compose" ENV="$env_json" python3 -c "
import json, os
print(json.dumps({
    'stackFileContent': os.environ['COMPOSE'],
    'env': json.loads(os.environ['ENV']),
    'prune': False,
    'pullImage': False
}))
")
    pt_api_put "$instance" "/stacks/$stack_id?endpointId=$eid" -d "$payload" > /dev/null
    ok "Environment variables updated for '$stack_name'."
}

cmd_edit() {
    local instance="${1:-$DEFAULT_INSTANCE}" stack_name="$2"
    shift 2 || { err "Usage: portainer edit <instance> <name> -f <file>"; exit 1; }
    local file=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -f|--file) file="$2"; shift 2 ;;
            *) file="$1"; shift ;;
        esac
    done
    [[ -z "$file" ]] && die "Usage: portainer edit <instance> <name> -f <file>"
    [[ -f "$file" ]] || die "Compose file not found: $file"

    local stack_id eid
    stack_id=$(resolve_stack_id "$instance" "$stack_name")
    eid="${ENDPOINT_IDS[$instance]}"

    # Get current env vars
    local stack_data env_vars
    stack_data=$(pt_api_get "$instance" "/stacks/$stack_id")
    env_vars=$(echo "$stack_data" | python3 -c "import sys,json; print(json.dumps(json.load(sys.stdin).get('Env', [])))")

    local new_compose
    new_compose=$(cat "$file")

    info "Updating compose and redeploying stack '$stack_name' on $instance..."
    local payload
    payload=$(COMPOSE="$new_compose" ENV="$env_vars" python3 -c "
import json, os
print(json.dumps({
    'stackFileContent': os.environ['COMPOSE'],
    'env': json.loads(os.environ['ENV']),
    'prune': True,
    'pullImage': True
}))
")
    pt_api_put "$instance" "/stacks/$stack_id?endpointId=$eid" -d "$payload" > /dev/null
    ok "Stack '$stack_name' updated and redeployed."
}

